test_transfer_amount_negative : Script ()
test_transfer_amount_negative = test_transfer_negative_generic $ \TestEnv {..} -> do
  let choiceArg = transferArgV2 with
        transfer = transferV2 with
          amount = -10.0
  pure $ (,) choiceArg $ expectMessageContains
    "The requirement 'Amount must be positive' was not met."

test_transfer_requestedAt : Script ()
test_transfer_requestedAt = test_transfer_negative_generic $ \TestEnv {..} -> do
  let choiceArg = transferArgV2 with
        transfer = transferV2 with
          requestedAt = now `addRelTime` microseconds 1
  pure $ (,) choiceArg $ expectErrorId  "stdlib.daml.com/deadline-not-exceeded"

test_transfer_executeBefore : Script ()
test_transfer_executeBefore = test_transfer_negative_generic $ \TestEnv {..} -> do
  let choiceArg = transferArgV2 with
        transfer = transferV2 with
          executeBefore = now `addRelTime` microseconds (-1)
  pure $ (,) choiceArg $ expectErrorId  "stdlib.daml.com/deadline-exceeded"
