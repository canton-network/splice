module Splice.Scripts.TestAmuletAllocationExpiry where

import DA.Assert

import Daml.Script

import DA.Time
import DA.TextMap qualified as TextMap

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.AllocationV1 qualified as V1
import Splice.Api.Token.AllocationV2 qualified as V2

import Splice.AmuletAllocation
import Splice.AmuletAllocationV2

import Splice.TokenStandard.Utils qualified as TSU

import Splice.Testing.Utils
import Splice.Testing.Registries.AmuletRegistryV2 qualified as AmuletRegistryV2
import Splice.Testing.Registries.TestRegistries qualified as TestRegistries
import Splice.Testing.TokenStandard.MultiRegistry qualified as MultiRegistry
import Splice.Testing.TokenStandard.RegistryApiV2 qualified as RegistryApiV2
import Splice.Testing.TokenStandard.WalletClientV2 qualified as WalletClientV2


-- Shared test setup
--------------------

data TestEnv = TestEnv with
  registries : MultiRegistry.MultiRegistry
  alice : Party
  aliceAccount : V2.Account
  bob : Party
  provider : Party
  instrId : V2.InstrumentId
  settlementV2 : V2.SettlementInfo
  allocationV2 : V2.AllocationSpecification
  allocationV1 : V1.AllocationSpecification


setupTest : Script TestEnv
setupTest = do
  env <- TestRegistries.initialize TestRegistries.defaultConfig
  let registries = env.registries
  let instrId = env.amuletV2.instrumentId

  alice <- allocatePartyExact "alice"
  bob <- allocatePartyExact "bob"
  provider <- allocatePartyExact "provider"

  let mkAccount = TSU.basicAccount

  -- setup alice
  WalletClientV2.createBatchingUtility alice
  AmuletRegistryV2.tapFaucet env.amuletV2 alice 1000.0

  now <- getTime
  pure TestEnv with
    registries
    alice
    aliceAccount = mkAccount alice
    bob
    provider
    instrId

    settlementV2 = V2.SettlementInfo with
      executors = [provider]
      id = "settlement1"
      cid = None
      meta = emptyMetadata
    allocationV2 = V2.AllocationSpecification with
      admin = instrId.admin
      authorizer = mkAccount alice
      transferLegSides = []
      committed = False
      nextIterationFunding = Some $ TextMap.fromList [(instrId.id, 10.0)]
      settlementDeadline = None
      meta = emptyMetadata

    allocationV1 = V1.AllocationSpecification with
      settlement = V1.SettlementInfo with
        executor = provider
        settlementRef = V1.Reference with
          id = "settlement1"
          cid = None
        requestedAt = now
        allocateBefore = now `addRelTime` days 7
        settleBefore = now `addRelTime` days 14
        meta = emptyMetadata
      transferLegId = "leg1"
      transferLeg = TSU.downcast_v2_v1_TransferLeg instrId.admin $ V2.TransferLeg with
        transferLegId = "leg1"
        sender = mkAccount alice
        receiver = mkAccount bob
        amount = 10.0
        instrumentId = instrId.id
        meta = emptyMetadata


-- Test expiry of V1 and V2 amulet allocations
----------------------------------------------

test_AmuletAllocationV2_DsoExpire : Script ()
test_AmuletAllocationV2_DsoExpire = do
  TestEnv {..} <- setupTest

  -- alice creates allocation
  WalletClientV2.allocateV2 registries alice settlementV2 allocationV2

  -- DSO expires
  let dso = instrId.admin
  registry <- MultiRegistry.getRegistryApiV2 registries dso
  [alloc] <- query @AmuletAllocationV2 dso
  let allocCid = toInterfaceContractId alloc._1
  context <- RegistryApiV2.getAllocation_CancelContext registry allocCid emptyMetadata

  -- expiry is 90 days in the future
  now <- getTime
  let expectedExpiresAt = now `addRelTime` days 90
  alloc._2.expiresAt === expectedExpiresAt

  let cancelCmd = exerciseCmd allocCid V2.Allocation_Cancel with
        actors = [dso]
        extraArgs = ExtraArgs with
          context = context.choiceContext
          meta = emptyMetadata

  -- cancel fails if we are before the expiry time
  submitMustFail dso cancelCmd

  -- cancel succeeds after expiry time
  setTime expectedExpiresAt
  result <- submit dso cancelCmd
  result.meta === TSU.reasonToMeta "cancelled expired allocation" emptyMetadata

  -- the allocation is gone
  [] <- query @AmuletAllocationV2 dso

  pure ()


test_AmuletAllocation_DsoExpire : Script ()
test_AmuletAllocation_DsoExpire = do
  TestEnv {..} <- setupTest

  -- alice creates allocation
  WalletClientV2.allocateV1 registries allocationV1

  -- DSO sees the allocation with the expected expiry
  let dso = instrId.admin
  [alloc] <- query @AmuletAllocation dso

  -- TODO(#4665): use the expiresAt field instead of settleBefore to support early expiry
  let expectedExpiresAt = allocationV1.settlement.settleBefore
  alloc._2.allocation.settlement.settleBefore === expectedExpiresAt

  -- DSO expires
  let allocCid = alloc._1
  let expireCommand = exerciseCmd allocCid AmuletAllocation_DsoExpire with
        expireLock = True

  -- expiry fails if we are before the expiry time
  submitMustFail dso expireCommand

  -- expiry succeeds after expiry time
  setTime expectedExpiresAt
  result <- submit dso expireCommand
  result.meta === TSU.reasonToMeta "cancelled expired allocation" emptyMetadata

  -- the allocation is gone
  [] <- query @AmuletAllocation dso

  pure ()
