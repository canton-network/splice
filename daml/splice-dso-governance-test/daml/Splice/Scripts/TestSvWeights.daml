module Splice.Scripts.TestSvWeights where

import DA.Assert
import DA.Action (void)
import DA.Foldable (forA_)
import DA.List (sort)
import DA.Map qualified as Map
import DA.Optional (fromOptional)

import Daml.Script

import Splice.Amulet
import Splice.Round
import Splice.Scripts.Util
import Splice.CometBft
import Splice.DsoRules
import Splice.DSO.SvState
import Splice.DSO.DecentralizedSynchronizer
import Splice.SvOnboarding

import Splice.Scripts.DsoTestUtils
import Splice.Testing.Registries.AmuletRegistry (getActiveOpenRoundsSorted)


test_SvWeightsFullyOnledger : Script ()
test_SvWeightsFullyOnledger = do

  -- Setup
  ---------

  (app, dso, (sv1, sv2, sv3, sv4)) <- initMainNet
  let sv5Alias = "SV5"
      sv5NodeName = sv5Alias <> "-node"
      sv5NodeParticipantId = sv5NodeName <> "-participant-id"
      -- hostedSv is hosted by SV operator sv5
      hostedSvName = "Hosted-SV"

  sv5 <- allocateParty sv5Alias
  hostedSv <- allocateParty hostedSvName
  -- hostedSv's extrabeneficary
  hostedSv_b <- allocateParty "Hosted_SV extra beneficiary"

  let hostedSvWeight = 100_000
      hostedSvBeneficiaries = [(hostedSv, 0.8), (hostedSv_b, 0.2)]
      hostedSvBeneficiariesMap = Map.fromList hostedSvBeneficiaries


  -- Onboarding an SV node (quick onboarding - check test below for real onboarding)
  -----------------------------------------------------------------------------------

  [(_, round), _, _] <- getActiveOpenRoundsSorted app.dso
  initiateAndAcceptVote app [sv1, sv2, sv3, sv4] $
    ARC_DsoRules with
      dsoAction = SRARC_AddSvNode DsoRules_AddSvNode with
        newSvOperatorParty = sv5
        newSvNodeName = sv5NodeName
        newSvNodeParticipantId = sv5NodeParticipantId

  assertSvInfoForParty app sv5 (mkSvInfo sv5NodeName round 0 sv5NodeParticipantId)
  assertSvRewardStateIsAbsent app sv5NodeName



  -- Onboarding a hosted SV
  --------------------------
  -- Add hostedSv with newSvOperator as SV operator
  -- Note: The onboarding flow creates a HostedSvRewardBeneficiaries contract with no beneficiaries

  [(_, round), _, _] <- getActiveOpenRoundsSorted app.dso
  let hostedSvJoinedAsOfRound = round
  initiateAndAcceptVote app [sv1, sv2, sv3, sv4, sv5] $
    ARC_DsoRules with
      dsoAction = SRARC_AddHostedSv DsoRules_AddHostedSv with
        newSvParty = hostedSv
        newSvName = hostedSvName
        newSvRewardWeight = hostedSvWeight
        joinedAsOfRound = hostedSvJoinedAsOfRound.round
        svOperator = sv5

  assertHostedSvInfoForParty app hostedSv
    (mkHostedSvInfo hostedSvName round hostedSvWeight sv5)

  assertHostedSvRewardBeneficiariesForSvAndOperator app hostedSv sv5
    HostedSvRewardBeneficiaries with
      dso
      sv = hostedSv
      svOperator = sv5
      beneficiaries = []


  -- Replace the default beneficiaries
  let hostedSvExtraBeneficiaries = [(hostedSv_b, unsafeLookup hostedSv_b hostedSvBeneficiariesMap)]
  hostedSvSvRewardBeneficiariesCid <- getSvRewardBeneficiariesCid app hostedSv sv5
  [(rulesCid, _)] <- query @DsoRules app.dso
  void $ submit (actAs hostedSv <> readAs dso) $
    exerciseCmd rulesCid DsoRules_SetHostedSvRewardBeneficiaries with
      hostedSvRewardBeneficiariesCid = hostedSvSvRewardBeneficiariesCid
      newBeneficiaries = hostedSvExtraBeneficiaries
      svParty = hostedSv

  assertHostedSvRewardBeneficiariesForSvAndOperator app hostedSv sv5
    HostedSvRewardBeneficiaries with
      dso
      sv = hostedSv
      svOperator = sv5
      beneficiaries = hostedSvExtraBeneficiaries


  -- Creating SV coupons
  -----------------------

  [(rulesCid, _)] <- query @DsoRules app.dso
  [(roundCid, round), _, _] <- getActiveOpenRoundsSorted app.dso

  -- sv5 creates coupons using the new DsoRules_ReceiveSvRewardCoupon_V2
  rewardStatesWithBeneficiaries <- getRewardStatesWithBeneficiariesBySvOperator app sv5
  void $ submit (actAs sv5 <> readAs dso) $
    exerciseCmd rulesCid DsoRules_ReceiveSvRewardCoupon_V2 with
      openRoundCid = roundCid
      rewardStatesWithBeneficiaries
      sv = sv5

  let expectedHostedSvCoupons = expectedSvCoupons hostedSvWeight hostedSvBeneficiaries
  assertSvCouponBeneficiariesForSv hostedSv round expectedHostedSvCoupons

  -- sv5 cannot create coupons using the legacy DsoRules_ReceiveSvRewardCoupon as
  -- there's no SvRewardState contract
  [] <- queryFilter @SvRewardState dso (\s -> s.svName == sv5NodeName)
  -- void $ submit (actAs sv5 <> readAs dso) $ exerciseCmd rulesCid DsoRules_ReceiveSvRewardCoupon with
  --   openRoundCid = roundCid
  --   rewardStateCid = undefined -- No contract
  --   beneficiaries = hostedSvBeneficiaries
  --   sv = sv5

  -- sv5 tries to create coupons using the new DsoRules_ReceiveSvRewardCoupon_V2 for the same round
  rewardStatesWithBeneficiaries <- getRewardStatesWithBeneficiariesBySvOperator app sv5
  void $ submitMustFail (actAs sv5 <> readAs dso) $
    exerciseCmd rulesCid DsoRules_ReceiveSvRewardCoupon_V2 with
      openRoundCid = roundCid
      rewardStatesWithBeneficiaries
      sv = sv5


  -- Updating SV weight
  ----------------------

  runNextIssuance app

  let updatedHostedSvWeight = hostedSvWeight - 10
  -- Update hostedSv weight (this includes the weight shared with hostedSv_b)
  initiateAndAcceptVote app [sv1, sv2, sv3, sv4, sv5] $
    ARC_DsoRules with
      dsoAction = SRARC_UpdateHostedSvWeight DsoRules_UpdateHostedSvWeight with
        svParty = hostedSv
        newRewardWeight = updatedHostedSvWeight

  assertHostedSvInfoForParty app hostedSv
    (mkHostedSvInfo hostedSvName round updatedHostedSvWeight sv5)

  -- Create SV coupons
  [(roundCid, round), _, _] <- getActiveOpenRoundsSorted app.dso
  [(rulesCid, _)] <- query @DsoRules app.dso
  rewardStatesWithBeneficiaries <- getRewardStatesWithBeneficiariesBySvOperator app sv5
  void $ submit (actAs sv5 <> readAs dso) $
    exerciseCmd rulesCid DsoRules_ReceiveSvRewardCoupon_V2 with
      openRoundCid = roundCid
      rewardStatesWithBeneficiaries
      sv = sv5

  let expectedHostedSvCoupons = expectedSvCoupons updatedHostedSvWeight hostedSvBeneficiaries
  assertSvCouponBeneficiariesForSv hostedSv round expectedHostedSvCoupons


  -- Updating the SV operator of a hosted SV
  --------------------------------------------
  -- Migrate hostedSv from sv2 to sv1

  -- Instruct update
  initiateAndAcceptVote app [sv1, sv2, sv3, sv4, sv5] $
    ARC_DsoRules with
      dsoAction = SRARC_InstructUpdateSvOperatorForHostedSv DsoRules_InstructUpdateSvOperatorForHostedSv with
        svParty = hostedSv
        newSvOperatorParty = sv1

  -- Update
  [(instructionCid, instruction)] <- query @UpdateSvOperatorForHostedSvInstruction dso
  [(hostedSvRewardBeneficiariesCid, _)] <- queryFilter @HostedSvRewardBeneficiaries dso (\co -> co.sv == instruction.svParty)
  void $ submit (actAs sv1 <> readAs dso) $
    exerciseCmd rulesCid DsoRules_UpdateSvOperatorForHostedSv with
      instructionCid
      hostedSvRewardBeneficiariesCid
      sv = sv1

  assertHostedSvInfoForParty app hostedSv
    (mkHostedSvInfo hostedSvName hostedSvJoinedAsOfRound updatedHostedSvWeight sv1)
  assertHostedSvRewardBeneficiariesForSvAndOperator app hostedSv sv1
    HostedSvRewardBeneficiaries with
      dso
      sv = hostedSv
      svOperator = sv1
      beneficiaries = hostedSvExtraBeneficiaries

  runNextIssuance app
  [(roundCid, round), _, _] <- getActiveOpenRoundsSorted app.dso
  [(rulesCid, _)] <- query @DsoRules app.dso

  -- sv5 creates coupons
  rewardStatesWithBeneficiaries <- getRewardStatesWithBeneficiariesBySvOperator app sv5
  void $ submit (actAs sv5 <> readAs dso) $
    exerciseCmd rulesCid DsoRules_ReceiveSvRewardCoupon_V2 with
      openRoundCid = roundCid
      rewardStatesWithBeneficiaries
      sv = sv5
  -- sv5 does not create coupons for the migrated hosted SV
  assertSvCouponBeneficiariesForSv hostedSv round []

  -- sv1 creates SV coupons
  rewardStatesWithBeneficiaries <- getRewardStatesWithBeneficiariesBySvOperator app sv1
  void $ submit (actAs sv1 <> readAs dso) $
    exerciseCmd rulesCid DsoRules_ReceiveSvRewardCoupon_V2 with
      openRoundCid = roundCid
      rewardStatesWithBeneficiaries
      sv = sv1

  let expectedHostedSvCoupons = expectedSvCoupons updatedHostedSvWeight hostedSvBeneficiaries
  assertSvCouponBeneficiariesForSv hostedSv round expectedHostedSvCoupons


  -- Clearing SV beneficiaries
  -----------------------------
  -- Remove hostedSv_b from beneficiaries, so hostedSv receives all the SV coupons

  runNextIssuance app

  -- Remove hostedSv_b's weight
  hostedSvSvRewardBeneficiariesCid <- getSvRewardBeneficiariesCid app hostedSv sv1
  void $ submit (actAs hostedSv <> readAs dso) $
    exerciseCmd rulesCid DsoRules_SetHostedSvRewardBeneficiaries with
      hostedSvRewardBeneficiariesCid = hostedSvSvRewardBeneficiariesCid
      newBeneficiaries = []
      svParty = hostedSv

  -- Create SV coupons
  [(roundCid, round), _, _] <- getActiveOpenRoundsSorted app.dso
  rewardStatesWithBeneficiaries <- getRewardStatesWithBeneficiariesBySvOperator app sv1
  void $ submit (actAs sv1 <> readAs dso) $
    exerciseCmd rulesCid DsoRules_ReceiveSvRewardCoupon_V2 with
      openRoundCid = roundCid
      rewardStatesWithBeneficiaries
      sv = sv1

  let expectedHostedSvCouponsAfterClear = [(hostedSv, updatedHostedSvWeight)]
  assertSvCouponBeneficiariesForSv hostedSv round expectedHostedSvCouponsAfterClear


  -- Offboarding a hosted SV node
  --------------------------------

  -- Instruct offboard
  initiateAndAcceptVote app [sv1, sv2, sv3, sv4, sv5] $
    ARC_DsoRules with
      dsoAction = SRARC_InstructOffboardHostedSv DsoRules_InstructOffboardHostedSv with
        svParty = hostedSv

  [(instructionCid, instruction)] <- query @OffboardHostedSvInstruction dso
  [(hostedSvRewardBeneficiariesCid, _)] <- queryFilter @HostedSvRewardBeneficiaries dso (\co -> co.sv == instruction.svParty)
  hostedSvInfo <- getHostedSvInfoByParty app instruction.svParty
  [(svRewardStateCid, _)] <- queryFilter @SvRewardState dso (\co -> co.svName == hostedSvInfo.name)

  -- Offboard
  void $ submit (actAs sv1 <> readAs dso) $
    exerciseCmd rulesCid DsoRules_OffboardHostedSv with
      instructionCid
      hostedSvRewardBeneficiariesCid
      svRewardStateCid
      sv = sv1

  [(_, rules)] <- query @DsoRules app.dso
  Map.lookup hostedSv (getHostedSvsMap rules) === None
  assertSvRewardStateIsAbsent app hostedSvInfo.name
  assertSvRewardBeneficiariesIsAbsent app hostedSv

  pure ()

test_SvWeightsMigration: Script ()
test_SvWeightsMigration = do

  -- Setup
  ---------
  (app, dso, (sv1, sv2, sv3, sv4)) <- initMainNet
  -- ghostSv is hosted by SV operator sv1
  let ghostSvName = "Ghost-SV"
  ghostSv <- allocateParty ghostSvName
  -- hostedSv is hosted by SV operator sv1
  let hostedSvName = "Hosted-SV"
  hostedSv <- allocateParty hostedSvName

  -- sv1's extrabeneficary
  sv1_b <- allocateParty "SV_1 extra beneficiary"
  -- hostedSv's extrabeneficary
  hostedSv_b <- allocateParty "Hosted_SV extra beneficiary"

  let sv1LegacyBeneficiaries =
        [ (sv1, 50_000)
        , (ghostSv, 20_000)
        , (hostedSv, 70_000)
        , (sv1_b, 50_000)
        , (hostedSv_b, 30_000)
        ]
      sv1TotalWeight = sum $ map snd sv1LegacyBeneficiaries
      sv1LegacyBeneficiariesMap = Map.fromList sv1LegacyBeneficiaries
      beneficiariesFromLegacy parties = map (\p -> (p, unsafeLookup p sv1LegacyBeneficiariesMap)) parties

  initiateAndAcceptVote app [sv1, sv2, sv3, sv4] $
    ARC_DsoRules with
      dsoAction = SRARC_UpdateSvRewardWeight DsoRules_UpdateSvRewardWeight with
        svParty = sv1
        newRewardWeight = sv1TotalWeight


  -- Creating SV coupons using the legacy DsoRules_ReceiveSvRewardCoupon
  -----------------------------------------------------------------------

  sv1SvInfo <- getSvInfoByParty app sv1
  [(rulesCid, _)] <- query @DsoRules app.dso
  [(roundCid, round), _, _] <- getActiveOpenRoundsSorted app.dso
  [(sv1RewardStateCid, _)] <- queryFilter @SvRewardState dso (\s -> s.svName == sv1SvInfo.name)
  void $ submit (actAs sv1 <> readAs dso) $ exerciseCmd rulesCid DsoRules_ReceiveSvRewardCoupon with
    openRoundCid = roundCid
    rewardStateCid = sv1RewardStateCid
    beneficiaries = sv1LegacyBeneficiaries
    sv = sv1
  assertSvCouponBeneficiariesForSv sv1 round sv1LegacyBeneficiaries


  -- SV migration
  ----------------

  runNextIssuance app
  [(roundCid, round), _, _] <- getActiveOpenRoundsSorted app.dso

  let sv1Beneficiaries = beneficiariesFromLegacy [sv1, sv1_b]
      hostedSvBeneficiaries = beneficiariesFromLegacy [hostedSv, hostedSv_b]
      ghostSvBeneficiaries = beneficiariesFromLegacy [ghostSv]

      sv1Weight = totalWeight sv1Beneficiaries
      hostedSvWeight = totalWeight hostedSvBeneficiaries
      ghostSvWeight = totalWeight ghostSvBeneficiaries

      sv1AsHostedSvName = sv1SvInfo.name <> "-hostedSV"
      svsMigrationData =
        [ mkSvMigrationData sv1 sv1AsHostedSvName sv1Weight [(sv1_b, 0.5)] -- sv1 itself is migrated as hosted SV
        , mkSvMigrationData hostedSv hostedSvName hostedSvWeight [(hostedSv_b, 0.3)]
        , mkSvMigrationData ghostSv ghostSvName ghostSvWeight []
        ]

  -- Migrate sv1, hostedSv and ghostSv
  [(sv1RewardStateCid, _)] <- queryFilter @SvRewardState dso (\s -> s.svName == sv1SvInfo.name)
  void $ submit (actAs sv1 <> readAs dso) $ exerciseCmd rulesCid DsoRules_MigrateHostedSvs with
    svsMigrationData
    openRoundCid = roundCid
    rewardStateCid = sv1RewardStateCid
    sv = sv1

  -- Check sv1 weight as SV operator is invalidated
  sv1SvInfo <- getSvInfoByParty app sv1
  sv1SvInfo.svRewardWeight === 0
  -- Check SvRewardState has been archived
  [] <- queryFilter @SvRewardState dso (\s -> s.svName == sv1SvInfo.name)
  -- Check hosted SVs
  [(rulesCid, rules)] <- query @DsoRules app.dso
  Map.size (getHostedSvsMap rules) === 3
  assertHostedSvInfoForParty app sv1 (mkHostedSvInfo sv1AsHostedSvName round sv1Weight sv1)
  assertHostedSvInfoForParty app hostedSv (mkHostedSvInfo hostedSvName round hostedSvWeight sv1)
  assertHostedSvInfoForParty app ghostSv (mkHostedSvInfo ghostSvName round ghostSvWeight sv1)
  -- Check hosted SVs SvRewardState contracts
  assertSingleSvRewardStateExists app sv1AsHostedSvName
  assertSingleSvRewardStateExists app hostedSvName
  assertSingleSvRewardStateExists app ghostSvName


  -- Creating SV coupons
  -----------------------

  -- Note: The legacy DsoRules_ReceiveSvRewardCoupon flow for sv1 as SV operator is invalidated
  -- once the migration becomes effective (There's no SvRewardState contract for sv1, and sv1's weight as SV operator was set to 0)
  [] <- queryFilter @SvRewardState dso (\s -> s.svName == sv1SvInfo.name)
  -- void $ submit (actAs newSvOperator <> readAs dso) $ exerciseCmd rulesCid DsoRules_ReceiveSvRewardCoupon with
  --   openRoundCid = roundCid
  --   rewardStateCid = undefined -- No contract
  --   beneficiaries = hostedSvBeneficiaries
  --   sv = newSvOperator

  [(roundCid, round), _, _] <- getActiveOpenRoundsSorted app.dso
  rewardStatesWithBeneficiaries <- getRewardStatesWithBeneficiariesBySvOperator app sv1
  void $ submit (actAs sv1 <> readAs dso) $
    exerciseCmd rulesCid DsoRules_ReceiveSvRewardCoupon_V2 with
      openRoundCid = roundCid
      rewardStatesWithBeneficiaries
      sv = sv1

  assertSvCouponBeneficiariesForSv sv1 round sv1Beneficiaries
  assertSvCouponBeneficiariesForSv hostedSv round hostedSvBeneficiaries
  assertSvCouponBeneficiariesForSv ghostSv round ghostSvBeneficiaries

  pure ()


testSvNodeOnboarding : Script ()
testSvNodeOnboarding = do
  (app, dso, (_, sv2, sv3, sv4)) <- initMainNet
  -- we now have enough SVs to achieve BFT for f = 1

  -- a new sv prepares his participant
  svX <- allocateParty "svX"

  -- we can't test token validity in Daml (it's a JWT)
  let token = "mock-token"

  -- sv2 initiates the onboarding of the new sv node
  svSubmits app sv2 $ \cid -> exerciseCmd cid $
    DsoRules_StartSvNodeOnboarding "svX" svX "svX-participant-id" token sv2

  -- an onboarding request for svX has been created
  [(_, svNodeOnboardingRequest)] <- query @SvNodeOnboardingRequest dso
  svNodeOnboardingRequest === SvNodeOnboardingRequest with
    candidateName = "svX"
    candidateParty = svX
    candidateParticipantId = "svX-participant-id"
    token
    sponsor = sv2
    dso
    expiresAt = svNodeOnboardingRequest.expiresAt

  -- svX collects three confirmations which is enough to onboard him
  [(dsoRulesCid, _)] <- query @DsoRules dso
  forA_ [sv2, sv3, sv4] $ \sv ->
    submit (actAs sv <> readAs dso) $ exerciseCmd dsoRulesCid DsoRules_ConfirmAction with
      confirmer = sv
      action = ARC_DsoRules with
        dsoAction = SRARC_ConfirmSvNodeOnboarding $ DsoRules_ConfirmSvNodeOnboarding with
          newSvOperatorParty = svX
          newSvNodeName = "svX"
          newNodeParticipantId = "svX-participant-id"
          reason = "because"
  executeAllConfirmedActions app

  -- svX is now a confirmed SV node
  [(svNodeOnboardingConfirmedCid, svNodeOnboardingConfirmed)] <- query @SvNodeOnboardingConfirmed dso
  svNodeOnboardingConfirmed === SvNodeOnboardingConfirmed with
    svOperatorParty = svX
    svNodeName = "svX"
    svNodeParticipantId = "svX-participant-id"
    reason = "because"
    dso
    expiresAt = svNodeOnboardingConfirmed.expiresAt

  -- once svX becomes able to read as DSO party (e.g., after party migration to svX's participant)...
  [(dsoRulesCid, _)] <- query @DsoRules dso

  -- onboarding fails if the time expired
  now <- getTime
  setTime svNodeOnboardingConfirmed.expiresAt

  submitMustFail (actAs svX <> readAs dso) $ exerciseCmd dsoRulesCid DsoRules_AddConfirmedSvNode with
    sv = svX
    svNodeOnboardingConfirmedCid

  -- reset the time to now
  setTime now

  -- svX completes its own onboarding by adding itself to the DsoRules
  submit (actAs svX <> readAs dso) $ exerciseCmd dsoRulesCid DsoRules_AddConfirmedSvNode with
    sv = svX
    svNodeOnboardingConfirmedCid

  checkSvStatusReports app

  [(_, dsoRules)] <- query @DsoRules dso

  now <- getTime
  -- now that svX is a sv it can set its CometBFT config to become a CometBFT  validator
  -- TODO(M3-59): add negative tests for limits enforced on config values (manual testing showed they work)
  let cometBftConfig = CometBftConfig with
        nodes = Map.fromList
          [ ( "svX-node-id-1"
            , CometBftNodeConfig with
                validatorPubKey = "==base-64-validator-pub-key-1"
                votingPower = 0
            )
          , ( "svX-node-id-2"
            , CometBftNodeConfig with
                validatorPubKey = "==base-64-validator-pub-key-1"
                votingPower = 1
            )
          ]
        governanceKeys = [GovernanceKeyConfig with pubKey = "==base-64-pubKey-1"]
        sequencingKeys = []

  let sequencerConfig = Some SequencerConfig with
        migrationId = 0
        sequencerId = "sequencer-id"
        url = "sequencer.address:1234"
        availableAfter = Some now

  let sequencerIdentityConfig = Some SequencerIdentityConfig with
        sequencerId = "sequencer-id"
        availableAfter = Some now

  let mediatorConfig = Some MediatorConfig with
        mediatorId = "mediator-id"

  let scanConfig = Some ScanConfig with
        publicUrl = "https://scan1234.example.com"

  let newNodeConfig = SynchronizerNodeConfig with
        cometBft = cometBftConfig
        sequencer = sequencerConfig
        sequencerIdentity = sequencerIdentityConfig
        mediator = mediatorConfig
        scan = scanConfig
        legacySequencerConfig = None
        physicalSynchronizers = None

  setSynchronizerNodeConfig app svX dsoRules.config.decentralizedSynchronizer.lastSynchronizerId newNodeConfig

  -- check that the config was actually set
  (_, nodeState) <- getSvNodeState app svX
  let actualConfig =
        Map.lookup dsoRules.config.decentralizedSynchronizer.lastSynchronizerId nodeState.state.synchronizerNodes
  actualConfig === Some newNodeConfig

  pure ()


-- Helpers
-----------

assertSvCouponBeneficiariesForSv : Party -> OpenMiningRound -> [(Party, Int)] -> Script ()
assertSvCouponBeneficiariesForSv sv round expected = do
  (_, coupons) <- unzip <$> queryFilter @SvRewardCoupon sv (\co -> co.round == round.round && co.sv == sv)
  let beneficiaries = map (\coupon -> (coupon.beneficiary, coupon.weight)) coupons
  sort beneficiaries === sort expected

assertNoSvRewardCouponsForSvInRound : Party -> OpenMiningRound -> Script ()
assertNoSvRewardCouponsForSvInRound sv round = do
  [] <- queryFilter @SvRewardCoupon sv (\co -> co.round == round.round && co.sv == sv)
  pure ()

assertSvCouponBeneficiariesInRound : AmuletApp -> OpenMiningRound -> [(Party, Int)] -> Script ()
assertSvCouponBeneficiariesInRound app round expected = do
  (_, coupons) <- unzip <$> queryFilter @SvRewardCoupon app.dso (\co -> co.round == round.round)
  let beneficiaries = map (\coupon -> (coupon.beneficiary, coupon.weight)) coupons
  sort beneficiaries === sort expected

assertHostedSvInfoForParty : AmuletApp -> Party -> HostedSvInfo -> Script ()
assertHostedSvInfoForParty app hostedSv expected = do
  hostedSvInfo <- getHostedSvInfoByParty app hostedSv
  hostedSvInfo === expected

assertSvInfoForParty : AmuletApp -> Party -> SvInfo -> Script ()
assertSvInfoForParty app sv expected = do
  svInfo <- getSvInfoByParty app sv
  svInfo === expected

assertHostedSvRewardBeneficiariesForSvAndOperator : AmuletApp -> Party -> Party -> HostedSvRewardBeneficiaries -> Script ()
assertHostedSvRewardBeneficiariesForSvAndOperator app hostedSv svOperator expected = do
  [(_, actual)] <- queryFilter @HostedSvRewardBeneficiaries app.dso (\b -> b.sv == hostedSv && b.svOperator == svOperator)
  actual === expected

assertSingleSvRewardStateExists : AmuletApp -> Text -> Script ()
assertSingleSvRewardStateExists app svName = do
  [_] <- queryFilter @SvRewardState app.dso (\s -> s.svName == svName)
  pure ()

assertSvRewardStateIsAbsent : AmuletApp -> Text -> Script ()
assertSvRewardStateIsAbsent app svName = do
  [] <- queryFilter @SvRewardState app.dso (\s -> s.svName == svName)
  pure ()

assertSvRewardBeneficiariesIsAbsent : AmuletApp -> Party -> Script ()
assertSvRewardBeneficiariesIsAbsent app sv = do
  [] <- queryFilter @HostedSvRewardBeneficiaries app.dso (\co -> co.sv == sv)
  pure ()

getHostedSvsMap : DsoRules -> Map.Map Party HostedSvInfo
getHostedSvsMap rules = fromOptional Map.empty rules.hostedSvs

mkHostedSvInfo : Text -> OpenMiningRound -> Int -> Party -> HostedSvInfo
mkHostedSvInfo name joinedAsOfRound svRewardWeight svOperator =
  HostedSvInfo with joinedAsOfRound = joinedAsOfRound.round; ..

mkSvInfo : Text -> OpenMiningRound -> Int -> Text -> SvInfo
mkSvInfo name joinedAsOfRound svRewardWeight participantId =
  SvInfo with joinedAsOfRound = joinedAsOfRound.round; ..

mkSvMigrationData : Party -> Text -> Int -> [(Party, Decimal)] -> SvMigrationData
mkSvMigrationData svParty svName svRewardWeight beneficaries = SvMigrationData with ..

unsafeLookup : (Ord k, Show k) => k -> Map.Map k v -> v
unsafeLookup key' m =
  case Map.lookup key' m of
    Some value -> value
    None -> error $ "Key not found: " <> show key'

getRewardStatesWithBeneficiariesBySvOperator
  : AmuletApp
  -> Party
  -> Script [(ContractId SvRewardState, ContractId HostedSvRewardBeneficiaries)]
getRewardStatesWithBeneficiariesBySvOperator app svOperator = do
  [(_, rules)] <- query @DsoRules app.dso
  let hostedSvsMap = getHostedSvsMap rules
      hostedSvsOperatedBySvOperator =
        filter (\(_, hostedSvInfo) -> hostedSvInfo.svOperator == svOperator) $
          Map.toList hostedSvsMap

  forA hostedSvsOperatedBySvOperator $ \(hostedSvParty, hostedSvInfo) -> do
    [(rewardStateCid, _)] <- queryFilter @SvRewardState app.dso (\s -> s.svName == hostedSvInfo.name)
    [hostedSvRewardBeneficiariesCid] <- map fst <$>
      queryFilter @HostedSvRewardBeneficiaries app.dso (\b -> b.sv  == hostedSvParty && b.svOperator == svOperator)
    pure (rewardStateCid, hostedSvRewardBeneficiariesCid)

totalWeight : [(Party, Int)] -> Int
totalWeight beneficiaries = sum (map snd beneficiaries)

getSvRewardBeneficiariesCid : AmuletApp -> Party -> Party -> Script (ContractId HostedSvRewardBeneficiaries)
getSvRewardBeneficiariesCid app hostedSv svOperator = do
  [(hostedSvSvRewardBeneficiariesCid, _)] <-
    queryFilter @HostedSvRewardBeneficiaries app.dso (\b -> b.sv  == hostedSv && b.svOperator == svOperator)
  pure hostedSvSvRewardBeneficiariesCid

expectedSvCoupons : Int -> [(Party, Decimal)] -> [(Party, Int)]
expectedSvCoupons svWeight beneficiaries =
  map (\(beneficiary, percentage) -> (beneficiary, floor (intToDecimal svWeight * percentage))) beneficiaries