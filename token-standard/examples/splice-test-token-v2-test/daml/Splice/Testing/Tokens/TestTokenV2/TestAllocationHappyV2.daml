-- | Test happy path V2 allocation API calls.
--
-- Note that batch settlement scenarios are tested as part of the token standard DvP tests.
module Splice.Testing.Tokens.TestTokenV2.TestAllocationHappyV2 where

import DA.Assert
import DA.List (sort)
import DA.Map qualified as Map
import DA.TextMap qualified as TextMap

import Daml.Script

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.AllocationInstructionV2 qualified as V2

import Splice.TokenStandard.Utils qualified as TSU

import Splice.Testing.Tokens.TestTokenV2 qualified as TestTokenV2

import Splice.Testing.Utils
import Splice.Testing.Registries.TestTokenV2_RegistryV2 qualified as TestTokenRegistryV2
import Splice.Testing.TokenStandard.RegistryApiV2 qualified as V2
import Splice.Testing.TokenStandard.WalletClientV2 qualified as WalletClientV2
import Splice.Testing.TokenStandard.MultiRegistry qualified as MultiRegistry

import Splice.Testing.Tokens.TestTokenV2.TokenStandardTestEnv (TestEnv(..), setupTest, checkEq)


-- V2 API: allocate, withdraw and cancel
----------------------------------------

test_allocation_WithdrawV2 : Script ()
test_allocation_WithdrawV2 = test_allocation_withdrawCancel_generic $ \TestEnv {..} allocCid -> do
  context <- V2.getAllocation_WithdrawContext registryV2 allocCid emptyMetadata
  submit (actAs alice <> discloseMany' context.disclosures) $
    exerciseCmd allocCid V2.Allocation_Withdraw with
      actors = [alice]
      extraArgs = ExtraArgs with
        context = context.choiceContext
        meta = emptyMetadata
  pure ()

-- TODO(tech-debt): add support for dealing with stale references to locked tokens
--
-- Handle them analogous to how Amulet handles them and copy the relevant tests from Amulet.
-- In particular:
--
--  - test_allocation_WithdrawV2_expiredLock
--  - test_allocation_WithdrawV2_missingLockContext : Script ()


test_allocation_CancelV2 : Script ()
test_allocation_CancelV2 = test_allocation_withdrawCancel_generic $ \TestEnv {..} allocCid -> do
  context <- V2.getAllocation_CancelContext registryV2 allocCid emptyMetadata
  submit (actAs provider <> discloseMany' context.disclosures) $
    exerciseCmd allocCid V2.Allocation_Cancel with
      actors = [provider]
      extraArgs = ExtraArgs with
        context = context.choiceContext
        meta = emptyMetadata
  pure ()

-- No test for allocationInstruction cancel, as instructions are not visible to
-- executors and thus do not have a cancel action.
test_allocationInstruction_WithdrawV2 : Script ()
test_allocationInstruction_WithdrawV2 = test_allocationInstruction_withdraw_generic $ \TestEnv {..} allocCid -> do
  context <- V2.getAllocationInstruction_WithdrawContext registryV2 allocCid emptyMetadata
  submit (actAs alice <> discloseMany' context.disclosures) $
    exerciseCmd allocCid V2.AllocationInstruction_Withdraw with
      actors = [alice]
      extraArgs = ExtraArgs with
        context = context.choiceContext
        meta = emptyMetadata
  pure ()


