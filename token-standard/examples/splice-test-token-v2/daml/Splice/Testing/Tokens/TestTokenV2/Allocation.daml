import Splice.Api.Token.AllocationV1 qualified as AllocationV1
import Splice.Api.Token.AllocationV2 qualified as AllocationV2
import Splice.Api.Token.AllocationInstructionV1 qualified as AllocationInstructionV1
import Splice.Api.Token.AllocationInstructionV2 qualified as AllocationInstructionV2


-- | Implementation of a V2-only allocation instruction
template TokenAllocationInstructionV2 with
    originalInstructionCid : Optional (ContractId V2.AllocationInstruction)
    actionAuthorizers : Map.Map V2.AllocationInstructionAction [Party]
      -- ^ A map from actions to which parties have already authorized that action.
      -- As soon as an action is fully authorized, it is executed.
      -- Specifically:
      -- AIA_Accept must be approved by all account parties of the authorizer.
      -- AIA_Withdraw must be approved by those account parties of the authorizer, which have
      -- already approved Accept.
    availableActions : Map.Map V2.AllocationInstructionAction [[Party]]
      -- ^ Stored results of mkAvailableAllocationActions at time of creation as we cannot
      -- access account contracts in view function.
    inputHoldingCids : TextMap.TextMap [ContractId V2.Holding]
    allocation : V2.AllocationSpecification
      -- ^ Allocation to create.
    admin : Party
    requestedAt : Time
  where
    ensure isValidAllocationSpecificationV2 (const True) allocation
    signatory fromOptional [] (Map.lookup V2.AIA_Accept actionAuthorizers), admin
    observer dedupSort (concatMap concat (Map.values availableActions) <> concat (Map.values actionAuthorizers))

    interface instance V2.AllocationInstruction for TokenAllocationInstructionV2 where
      view = V2.AllocationInstructionView with
        originalInstructionCid
        allocation
        requestedAt
        inputHoldingCids = Foldable.concat inputHoldingCids
        availableActions
        expiresAt =
          -- Note: in prod you would probably want to limit the maximal TTL to avoid a storage leak
          allocation.settlement.settlementDeadline
        meta = emptyMetadata

      -- No extra observers required, as the choice bodies do not introduce further informees.
      -- Note that the executors are controllers on these two choices.
      allocationInstruction_withdrawExtraObservers _arg = []
      allocationInstruction_acceptExtraObservers _arg = []

      allocationInstruction_withdrawImpl self arg = do
        applyAllocationInstructionTransitions this (Some self) arg.actors V2.AIA_Withdraw arg.extraArgs

      allocationInstruction_acceptImpl self arg = do
        applyAllocationInstructionTransitions this (Some self) arg.actors V2.AIA_Accept arg.extraArgs

applyAllocationInstructionTransitions
  : TokenAllocationInstructionV2
  -> Optional (ContractId V2.AllocationInstruction)
  -> [Party]
  -> V2.AllocationInstructionAction
  -> ExtraArgs
  -> Update V2.AllocationInstructionResult
applyAllocationInstructionTransitions this@TokenAllocationInstructionV2{..} oSelf actors action extraArgs = do

  accountMap <- extractAccountConfigMap
      this.admin
      extraArgs
      [this.allocation.authorizer]

  let
    admin = this.admin
    stateMachine = allocationInstructionStateMachineSpec this.allocation.authorizer

    mkPending newActionAuthorizers newAvailableActions = do
      pendingInstrCid <- create this with
        originalInstructionCid = fmap coerceContractId oSelf
        actionAuthorizers = newActionAuthorizers
        availableActions = newAvailableActions
      return V2.AllocationInstructionResult with
            output = V2.AllocationInstructionResult_Pending with
              allocationInstructionCid = toInterfaceContractId pendingInstrCid
            authorizerChangeCids = TextMap.empty
            meta = emptyMetadata

    tryUseAuthority actors action result authState accountMap extraArgs = case result.output of
      V2.AllocationInstructionResult_Pending instrCid ->
        tryUseAccountAuthorityForAIA' actors action instrCid authState accountMap extraArgs
      _ -> return None

    transition fromState toState =  case (fromState, toState) of

      (AIS_Init, AIS_Withdrawn) ->
        pure V2.AllocationInstructionResult with
            output = V2.AllocationInstructionResult_Failed
            authorizerChangeCids = inputHoldingCids
            meta = emptyMetadata

      (AIS_Init, AIS_Accepted) -> do
          let allocationSpec = allocationStateMachineSpec allocation.authorizer allocation.settlement.executors allocation.admin
          eventLogCid <- getEventLogFromContext extraArgs.context
          (lockedTokens, authorizerChangeCids) <- splitAndLock eventLogCid allocation inputHoldingCids
          allocationCid <- create TokenAllocationV2 with
            originalAllocationCid = None
            availableActions = mkAvailableActions admin allocationSpec Map.empty accountMap
            actionAuthorizers = Map.empty
            createdAt = requestedAt
            ..
          pure V2.AllocationInstructionResult with
            output = V2.AllocationInstructionResult_Completed (coerceContractId allocationCid)
            authorizerChangeCids
            meta = emptyMetadata

      x -> abort $ "Unsupported state transition: " <> show x

  applyStateMachineTransitions
    admin this oSelf actors action stateMachine accountMap transition
    mkPending tryUseAuthority extraArgs




-- | Implementation of a V2-only allocation.
template TokenAllocationV2 with
    originalAllocationCid : Optional (ContractId V2.Allocation)
    actionAuthorizers : Map.Map V2.AllocationAction [Party]
      -- ^ A map from actions to which parties have already authorized that action.
      -- As soon as an action is fully authorized, it is executed.
      -- Specifically:
      -- AA_Withdraw must be approved by those account parties of the sender, which have
      -- already approved Accept.
    availableActions : Map.Map V2.AllocationAction [[Party]]
      -- ^ Stored results of mkAvailableAllocationActions at time of creation as we cannot
      -- access account contracts in view function.
    lockedTokens : TextMap.TextMap [ContractId V2.Holding]
      -- ^ Map from instrumentId to holdings.
    allocation : V2.AllocationSpecification
    createdAt : Time
  where
    ensure isValidAllocationSpecificationV2 (const True) allocation
    signatory accountParties allocation.admin allocation.authorizer, allocation.admin
    observer allocation.settlement.executors

    interface instance V2.Allocation for TokenAllocationV2 where
      view = V2.AllocationView with
        originalAllocationCid
        expiresAt = None
          -- Note: in a production implementation we would also want to add a choice
          -- for the `admin` to expire the allocation. We don't need it for testing though.
        allocation
        holdingCids = Foldable.concat lockedTokens
        availableActions = allocationV2_availableActionsDefault allocation
        createdAt
        numIterations = 0  -- TODO(#5464): support iterated settlement in V2 token
        meta = emptyMetadata

      -- No extra observers required, as the choice bodies do not introduce further informees.
      -- Note that the executors are controllers on these two choices.
      allocation_settleExtraObservers _arg = []
      allocation_cancelExtraObservers _arg = []

      -- Add executors as extra observers so there is no extra view for the archival of the holding
      allocation_withdrawExtraObservers _arg = allocation.settlement.executors

      allocation_withdrawImpl self arg = do
        applyAllocationTransitions this (Some self) arg.actors V2.AA_Withdraw arg.extraArgs

      allocation_cancelImpl self arg = do
        applyAllocationTransitions this (Some self) arg.actors V2.AA_Cancel arg.extraArgs

      allocation_settleImpl self arg = do
        applyAllocationTransitions this (Some self) arg.actors V2.AA_Settle arg.extraArgs


applyAllocationTransitions
  : HasArchive allocation
  => TokenAllocationV2
  -> Optional (ContractId allocation)
  -> [Party]
  -> V2.AllocationAction
  -> ExtraArgs
  -> Update V2.AllocationResult
applyAllocationTransitions this@TokenAllocationV2{..} oSelf actors action extraArgs = do

  accountMap <- extractAccountConfigMap
      this.allocation.admin
      extraArgs
      [this.allocation.authorizer]

  let
    admin = this.allocation.admin
    stateMachine = allocationStateMachineSpec this.allocation.authorizer this.allocation.settlement.executors this.allocation.admin

    mkPending newActionAuthorizers newAvailableActions = do
      pendingInstrCid <- create this with
        originalAllocationCid = fmap coerceContractId oSelf
        actionAuthorizers = newActionAuthorizers
        availableActions = newAvailableActions
      return V2.AllocationResult with
            output = V2.AllocationResult_Pending with
              allocationCid = toInterfaceContractId pendingInstrCid
            authorizerHoldingCids = TextMap.empty
            meta = emptyMetadata

    tryUseAuthority actors action result authState accountMap extraArgs = case result.output of
      V2.AllocationResult_Pending allocationCid ->
        tryUseAccountAuthorityForAA' actors action allocationCid authState accountMap extraArgs
      _ -> return None

    transition fromState toState =  case (fromState, toState) of

      (AS_Init, AS_Withdrawn) -> do
        ensureWithdrawIsAllowed allocation
        authorizerHoldingCids <- unlockTokenAllocationV2 "allocation withdrawn" this extraArgs
        pure V2.AllocationResult
          with
            output = V2.AllocationResult_Withdrawn
            authorizerHoldingCids
            meta = emptyMetadata

      (AS_Init, AS_Cancelled) -> do
        authorizerHoldingCids <- unlockTokenAllocationV2 "allocation cancelled" this extraArgs
        pure V2.AllocationResult
          with
            output = V2.AllocationResult_Cancelled
            authorizerHoldingCids
            meta = emptyMetadata

      (AS_Init, AS_Settled) -> do
        -- check deadline
        forA_ allocation.settlement.settlementDeadline $ \deadline ->
          assertWithinDeadline "allocation.settlement.settlementDeadline" deadline

        -- archive the locked tokens
        debitAmounts <- fmap (TextMap.fromListWithR (+)) $ forA (Foldable.concat lockedTokens) $ \cid -> do
          token <- fetch cid
          let holding = view token
          archive cid
          require' ("lockedToken", holding.account) isEqualR ("allocation.authorizer", allocation.authorizer)
          require' ("lockedToken.instrumentId.admin", holding.instrumentId.admin) isEqualR ("allocation.admin", allocation.admin)
          pure (holding.instrumentId.id, holding.amount)

        -- prudent engineering: compare debits with expected debits based on the transfer legs, and settle
        let creditAmounts = netAllocationCreditAmounts allocation.admin allocation.authorizer allocation.transferLegSides
        let combinedAmounts = mergeAmountMaps debitAmounts creditAmounts
        authorizerHoldingCids0 <- forA (TextMap.toList combinedAmounts) $ \(instrumentId, (debitAmount, creditAmount)) -> do
          require'
            ("archived lockedAmulet.amount for " <> show instrumentId, debitAmount)
            isEqualR
            ("transferLegs.debitAmount", negate (min 0.0 creditAmount))
          if creditAmount > 0.0
            then do
              -- Net credit of Token ==> create the holding
              newHoldingCid <- create Token with
                holding = V2.HoldingView with
                  account = allocation.authorizer
                  amount = creditAmount
                  instrumentId = V2.InstrumentId with
                    id = instrumentId
                    admin = allocation.admin
                  lock = None
                  meta = emptyMetadata
              pure (instrumentId, [toInterfaceContractId newHoldingCid])
            else
              -- No credit of Token ==> no holding change
              pure (instrumentId, [])

        -- log v2 transfer events
        tokenRulesCid <- getEventLogFromContext extraArgs.context
        let authorizerHoldingCids = TextMap.fromListWithR (++) $ authorizerHoldingCids0
        logAllocationSettlement (toInterfaceContractId tokenRulesCid)
          (concat $ textMapValues lockedTokens)
          allocation
          (concat $ textMapValues authorizerHoldingCids)

        pure V2.AllocationResult with
          output = V2.AllocationResult_Settled with
            nextIterationAllocationCid = None -- TODO(#5464): support iterated settlement in V2 token
          authorizerHoldingCids = authorizerHoldingCids
          meta = emptyMetadata
            -- Note: for V1 tx history we would need create extra choices for
            -- the creation, as this choice here cannot express the creation and
            -- archival of multiple holdings for different instrument-ids.

      x -> abort $ "Unsupported state transition: " <> show x

  applyStateMachineTransitions
    admin this oSelf actors action stateMachine accountMap
    transition mkPending tryUseAuthority extraArgs

-- | Create a locked input for an allocation.
splitAndLock : ContractId TransferEventsV2.EventLog -> V2.AllocationSpecification -> TextMap.TextMap [ContractId V2.Holding] -> Update (TextMap.TextMap [ContractId V2.Holding], TextMap.TextMap [ContractId V2.Holding])
splitAndLock eventLogCid allocation inputTokenCids = do

  -- debit all input amounts
  inputAmounts <- TextMap.fromListWithR (+) . concat <$> forA (TextMap.toList inputTokenCids) (\(_, cids) -> forA cids (\cid -> do
      let tokenCid = coerceContractId cid : ContractId Token
      token <- fetch tokenCid
      archive tokenCid
      pure (token.holding.instrumentId.id, token.holding.amount)
      ))

  -- create locked tokens and change for the sender
  let creditAmounts = netAllocationCreditAmounts allocation.admin allocation.authorizer allocation.transferLegSides
  let combinedAmounts = mergeAmountMaps inputAmounts creditAmounts
  locksAndChange <- forA (TextMap.toList combinedAmounts) $ \(instrumentId, (inputAmount, creditAmount)) -> do
    let netAmount = min 0.0 creditAmount + inputAmount
    when (netAmount < 0.0) $
      fail $ T.unlines
        [ "Net debit of " <> show netAmount <> " for " <> show instrumentId <> " is not allowed"
        , "Input amount: " <> show inputAmount
        , "Credit amount: " <> show creditAmount
        ]
    lockedTokens <-
      if creditAmount >= 0.0 then pure [] else do
        cid <- create Token with
          holding = V2.HoldingView with
            account = allocation.authorizer
            amount = negate creditAmount
            instrumentId = V2.InstrumentId with
              id = instrumentId
              admin = allocation.admin
            lock = Some $ V2.Lock with
              holders = allocation.admin :: accountParties allocation.admin allocation.authorizer
              expiresAt = allocation.settlement.settlementDeadline
              expiresAfter = None
              context = Some $ "allocation for settlement of " <> allocation.settlement.settlementRef.id
            meta = emptyMetadata
        pure [(instrumentId, [toInterfaceContractId cid])]
    changeTokens <-
      if netAmount <= 0.0 then pure [] else do
        cid <- create Token with
          holding = V2.HoldingView with
            account = allocation.authorizer
            amount = netAmount
            instrumentId = V2.InstrumentId with
              id = instrumentId
              admin = allocation.admin
            lock = None
            meta = emptyMetadata
        pure [(instrumentId, [toInterfaceContractId cid])]
    pure (lockedTokens, changeTokens)

  let
    lockedCids = TextMap.fromListWithR (++) $ concatMap fst locksAndChange
    authorizerChangeCids = TextMap.fromListWithR (++) $ concatMap snd locksAndChange

  -- log the tx history v2 event
  logHoldingsChange eventLogCid TransferEventsV2.EventLog_HoldingsChange with
    admin = allocation.admin
    account = allocation.authorizer
    inputHoldingCids = concat (textMapValues inputTokenCids)
    transferLegSides = []
    outputHoldingCids = concat (textMapValues lockedCids) <> concat (textMapValues authorizerChangeCids)
    observers = accountParties allocation.admin allocation.authorizer
    extraArgs = ExtraArgs with
      context = emptyChoiceContext
      meta = reasonToMeta ("lock holdings for allocation") emptyMetadata

  return (lockedCids, authorizerChangeCids)


-- Utilities
------------

unlockTokenAllocationV2 : Text -> TokenAllocationV2 -> ExtraArgs -> Update (TextMap.TextMap [ContractId V2.Holding])
unlockTokenAllocationV2 reason tokenAllocation extraArgs = do
  authorizerCids <- Traversable.forA tokenAllocation.lockedTokens $ \cids ->
    forA cids $ \lockedCid -> do
      token <- fetch lockedCid
      let holding = view token
      archive lockedCid
      require' ("lockedToken", holding.account) isEqualR ("allocation.authorizer", tokenAllocation.allocation.authorizer)
      toInterfaceContractId <$> create Token with
        holding = holding with lock = None
  eventLogCid <- getEventLogFromContext extraArgs.context
  let admin = tokenAllocation.allocation.admin
  logHoldingsChange eventLogCid TransferEventsV2.EventLog_HoldingsChange with
    admin
    account = tokenAllocation.allocation.authorizer
    inputHoldingCids = concat (textMapValues tokenAllocation.lockedTokens)
    transferLegSides = []
    outputHoldingCids = concat (textMapValues authorizerCids)
    observers = accountParties admin tokenAllocation.allocation.authorizer
    extraArgs = ExtraArgs with
      context = emptyChoiceContext
      meta = reasonToMeta reason emptyMetadata
  pure authorizerCids


-- V1 compatibility for allocations
-----------------------------------

-- FIXME: run the pure V1 API tests against this implementation

-- | We model V1 allocations as a subset of V2 allocations.
--
-- We can't directly implement the `V1.Allocation` interface on `TokenAllocationV2`
-- as that would result in errors in the interface view implementation when it has to downcast
-- a V2.Allocation with multiple legs. This approach here let's us share the logic while
-- keeping the templates separate.
template TokenAllocationV1 with
    allocationV2 : TokenAllocationV2
    settleAt : Time
  where
    ensure
      (ensure allocationV2) &&
      isSome (downcast_v2_v1_allocationView settleAt (view (toInterface @V2.Allocation allocationV2)))
    signatory allocationV2.allocation.admin

    interface instance AllocationV1.Allocation for TokenAllocationV1 where
      view = fromSomeNote "unexpected: downcast failed for TokenAllocationV1" $
        downcast_v2_v1_allocationView settleAt (view (toInterface @V2.Allocation allocationV2))

      allocation_executeTransferImpl self arg = do
        tokenRulesCid <- getTokenRulesFromContext arg.extraArgs.context
        let allocationFactoryCid = coerceContractId tokenRulesCid
        let settlementFactoryCid = coerceContractId tokenRulesCid
        allocation_v1_executeTransferDefaultImplUsingV2
          allocationFactoryCid
          settlementFactoryCid
          (toInterface allocationV2) self arg
        -- applyAllocationTransitions allocationV2 (allocationV2.originalAllocationCid) arg.actors V2.AA_Settle arg.extraArgs

      allocation_cancelImpl self arg =
        error "impl"
        -- applyAllocationTransitions allocationV2 (allocationV2.originalAllocationCid) arg.actors V2.AA_Cancel arg.extraArgs

      allocation_withdrawImpl self arg =
        error "impl"
        -- applyAllocationTransitions allocationV2 (allocationV2.originalAllocationCid) arg.actors V2.AA_Withdraw arg.extraArgs

-- canDowncast_v2_v1_allocationView : HasToInterface t V2.Allocation => t -> Bool
-- canDowncast_v2_v1_allocationView = isSome . downcast_v2_v1_allocationView . view . toInterface @V2.Allocation

-- FIXME
downcast_v2_v1_allocationView : Time -> V2.AllocationView -> Optional AllocationV1.AllocationView
downcast_v2_v1_allocationView settleAt v2View = do
  -- FIXME: check that settlement is allowed
  let v2Allocation = v2View.allocation
  guard (isNone v2Allocation.nextIterationFunding && not v2Allocation.committed)
  [transferLegSide] <- Some v2View.allocation.transferLegSides
  guard (transferLegSide.side == AllocationV2.SenderSide)
  let v2TransferLeg = transferLegFromSide v2Allocation.authorizer transferLegSide
  pure AllocationV1.AllocationView with
    allocation = AllocationV1.AllocationSpecification with
      settlement = downcast_v2_v1_SettlementInfo v2View.createdAt settleAt v2View.allocation.settlement
      transferLegId = v2TransferLeg.transferLegId
      transferLeg = downcast_v2_v1_TransferLeg v2View.allocation.admin v2TransferLeg
    holdingCids = map downcast v2View.holdingCids
    meta = v2View.meta

-- canBeDowncastToV1 : TokenAllocationV2 -> Bool
-- canBeDowncastToV1 _ = True -- FIXME: check number of transfer legs




-- | Adapter to implement `V1.AllocationInstruction_Withdraw` using the body of the V2 choice.
--
-- Built as an adapter, as calling the V2 interface method directly is not possible, as that will
-- archive the allocation instruction again.
allocationInstruction_v1_withdrawDefaultImplUsingV2
  : AllocationInstructionV2.AllocationInstruction
  -> (ContractId AllocationInstructionV2.AllocationInstruction -> AllocationInstructionV2.AllocationInstruction_Withdraw -> Update AllocationInstructionV2.AllocationInstructionResult)
  -> ContractId AllocationInstructionV1.AllocationInstruction -> AllocationInstructionV1.AllocationInstruction_Withdraw -> Update AllocationInstructionV1.AllocationInstructionResult
allocationInstruction_v1_withdrawDefaultImplUsingV2 this v2Impl self arg = do
  let thisView = view this
  result <- v2Impl (coerceInterfaceContractId self) AllocationInstructionV2.AllocationInstruction_Withdraw with
    actors = [regularAccountOwner thisView.allocation.authorizer]
    extraArgs = arg.extraArgs
  pure (downcast result)

-- | Default method for `V1.AllocationFactory_Allocate` that uses the V2 allocation implementation under the hood.
allocationFactory_v1_allocationDefaultImplUsingV2
  : AllocationInstructionV2.AllocationFactory
  -> ContractId AllocationInstructionV1.AllocationFactory -> AllocationInstructionV1.AllocationFactory_Allocate -> Update AllocationInstructionV1.AllocationInstructionResult
allocationFactory_v1_allocationDefaultImplUsingV2 this self arg = do
  let allocation = arg.allocation
  let thisView = view this
  requireMatchExpected ("arg.expectedAdmin", arg.expectedAdmin) thisView.admin
  result <- AllocationInstructionV2.allocationFactory_allocateImpl this (coerceInterfaceContractId self) AllocationInstructionV2.AllocationFactory_Allocate with
    actors = [arg.allocation.transferLeg.sender]
    requestedAt = allocation.settlement.requestedAt
    inputHoldingCids = map coerceContractId arg.inputHoldingCids
    allocation = upcast allocation
    extraArgs = arg.extraArgs
  pure (downcast result)

allocation_v1_executeTransferDefaultImplUsingV2
  : ContractId AllocationInstructionV2.AllocationFactory
  -> ContractId AllocationV2.SettlementFactory
  -> AllocationV2.Allocation
  -> ContractId AllocationV1.Allocation
  -> AllocationV1.Allocation_ExecuteTransfer -> Update AllocationV1.Allocation_ExecuteTransferResult
allocation_v1_executeTransferDefaultImplUsingV2 allocationFactoryCid settlementFactoryCid v2SenderAllocation v1SenderAllocCid arg = do
  -- prudent engineering: check that sender allocation has v1 shape
  let v2SenderAllocView = view (toInterface @V2.Allocation v2SenderAllocation)
  let v1SenderAllocView =
        fromSomeNote "unexpected: downcast failed for sender allocation in allocation_v1_executeTransferDefaultImplUsingV2" $
        downcast_v2_v1_allocationView v2SenderAllocView.createdAt v2SenderAllocView -- Note: for the downcast it is OK to pass createdAt as a stub
  guard (isSome (downcast_v2_v1_allocationView v2SenderAllocView.createdAt v2SenderAllocView))
  [v2SenderTransferLegSide] <- pure v2SenderAllocView.allocation.transferLegSides -- FIXME: erro message
  -- allocate receiver allocation
  let v2TransferLeg = transferLegFromSide v2SenderAllocView.allocation.authorizer v2SenderTransferLegSide
  let v2ReceiverAlloc = AllocationV2.AllocationSpecification with
          admin = v2SenderAllocView.allocation.admin
          authorizer = v2TransferLeg.receiver
          settlement = v2SenderAllocView.allocation.settlement
          transferLegSides = [receiverSide v2TransferLeg]
          nextIterationFunding = None
          committed = False
          meta = emptyMetadata

  allocResult <- exercise allocationFactoryCid AllocationInstructionV2.AllocationFactory_Allocate with
    allocation = v2ReceiverAlloc
    inputHoldingCids = []
    requestedAt = v1SenderAllocView.allocation.settlement.requestedAt
    actors = [v1SenderAllocView.allocation.transferLeg.receiver]
    extraArgs = arg.extraArgs

  let v2ReceiverAllocCid = case allocResult.output of
        V2.AllocationInstructionResult_Completed allocCid -> allocCid
        _ -> error "unexpected: allocation failed in allocation_v1_executeTransferDefaultImplUsingV2"

  -- settle batch of the two allocations
  result <- exercise settlementFactoryCid AllocationV2.SettlementFactory_SettleBatch with
    settlement = v2SenderAllocView.allocation.settlement
    transferLegs = [v2TransferLeg]
    allocations =
      [ nonIteratedAllocation (coerceInterfaceContractId v1SenderAllocCid)
      , nonIteratedAllocation v2ReceiverAllocCid
      ]
    actors = [v1SenderAllocView.allocation.settlement.executor]
    extraArgs = arg.extraArgs

  let [senderResult, receiverResult] = result.allocationSettleResults

  pure AllocationV1.Allocation_ExecuteTransferResult with
    senderHoldingCids = map downcast $ concat $ textMapValues senderResult.authorizerHoldingCids
    receiverHoldingCids = map downcast $ concat $ textMapValues receiverResult.authorizerHoldingCids
    meta = emptyMetadata -- FIXME


