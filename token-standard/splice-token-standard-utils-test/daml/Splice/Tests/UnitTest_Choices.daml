-- | Unit tests for Splice.TokenStandard.Utils.Internal.Choices
module Splice.Tests.UnitTest_Choices where

import DA.Action (when, unless)
import DA.Foldable (forA_)
import DA.Text qualified as T
import DA.TextMap as TextMap

import Daml.Script

import Splice.TokenStandard.Utils qualified as TSU

import Splice.Tests.TokenStandard.UnitTestUtils


test_predicates : Script ()
test_predicates = do
    testPredicate TSU.isMemberR
      [ (1, [1,2,3])
      , (2, [1,2,3])
      ]
      [ (1, [2,3,4])
      , (4, [1,2,3])
      ]
    testPredicate TSU.isEqualR
      [ (1, 1) ]
      [ (1, 2) ]
    testPredicate TSU.isEqualSetR
      [ ([1], [1])
      , ([2,1], [1,2])
      ]
      [ ([1], [1,2])
      , ([2,1,0], [1,2])
      ]
    testPredicate TSU.isSubsetOfR
      [ ([1,1], [1,2,3,3])
      , ([1,2], [1,2,3])
      ]
      [ ([2,1,3], [1,2])
      , ([2,3], [1,2,2])
      ]
    testPredicate (TSU.notR TSU.isEqualR)
      [ (1, 2) ]
      [ (1, 1) ]
    testPredicate (TSU.oneOfR TSU.isEqualSetR)
      [ ([1,1], [[1,2,3], [1], [2,2]])
      , ([2,1], [[1,2,3], [1], [2,2,1]])
      ]
      [ ([2,1], [[1], [1], [2,2]])]
    testPredicate TSU.isGreaterOrEqualR
      [ (2, 1), (2, 2) ]
      [ (1, 2) ]
    testPredicate TSU.isGreaterR
      [ (2, 1) ]
      [ (1, 2), (2, 2) ]
    testPredicate TSU.isLessR
      [ (1, 2) ]
      [ (2, 1), (2, 2) ]
    testPredicate TSU.isLessOrEqualR
      [ (1, 2), (2, 2) ]
      [ (2, 1) ]
  where
    testPredicate : (Show a, Show b) => (Text, a -> b -> Bool) -> [(a, b)] -> [(a,b)] -> Script ()
    testPredicate (name, p) mustBeTrue mustBeFalse = do
      forA_ mustBeTrue $ \(a, b) -> do
        unless (p a b) $
          fail $ T.unlines
            [ "Predicate not '" <> name <> "' returned false for values that should satisfy it."
            , "lhs:" <> show a
            , "rhs:" <> show b
            ]
      forA_ mustBeFalse $ \(a, b) -> do
        when (p a b) $
          fail $ T.unlines
            [ "Predicate not '" <> name <> "' returned true for values that should not satisfy it."
            , "lhs:" <> show a
            , "rhs:" <> show b
            ]

test_textMap : Script ()
test_textMap = do
  let m1 = TextMap.fromList [("a", 1), ("b", 2)]
  let m2 = TextMap.fromList [("b", 10), ("c", 20)]

  checkEq "textMapUnionWith"
    (TSU.textMapUnionWith (+) m1 m2)
    (TextMap.fromList [("a", 1), ("b", 12), ("c", 20)])

  checkEq "textMapMergeWithDefault"
    (TSU.textMapMergeWithDefault (100, 200) m1 m2)
    (TextMap.fromList [("a", (1, 200)), ("b", (2, 10)), ("c", (100, 20))])

  checkEq "textMapZip"
    (TSU.textMapZip m1 m2)
    (TextMap.fromList [("a", (Some 1, None)), ("b", (Some 2, Some 10)), ("c", (None, Some 20))])

