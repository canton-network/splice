-- | Unit tests for Splice.TokenStandard.Utils.Internal.Allocations
module Splice.Tests.UnitTest_Allocations where

import DA.Action (unless)
import DA.Assert
import DA.Map qualified as Map
import DA.Time
import DA.Text qualified as T
import DA.TextMap qualified as TextMap

import Daml.Script

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.HoldingV1 qualified as V1
import Splice.Api.Token.AllocationV1 qualified as V1
import Splice.Api.Token.AllocationV2 qualified as V2

import Splice.TokenStandard.Utils qualified as TSU

-- TODO(#4517): add more unit tests for the non-trivial functions

test_executorsFromSettlementInfoV1 : Script ()
test_executorsFromSettlementInfoV1 = do
  now <- getTime
  provider1 <- allocateParty "provider1"
  provider2 <- allocateParty "provider2"
  let settlementV2 = V1.SettlementInfo with
        executor = provider1
        settlementRef = V1.Reference with
          id = "settlement1"
          cid = None
        meta = Metadata with
          values = TextMap.fromList
            [ (TSU.extraExecutorsMetaField, partyToText provider2)
            ]
        requestedAt = now
        allocateBefore = now `addRelTime` days 1
        settleBefore = now `addRelTime` days 2

  TSU.executorsFromSettlementInfoV1 settlementV2 === [provider1, provider2]

  pure ()


test_allocationV1_availableActionsDefault : Script ()
test_allocationV1_availableActionsDefault = do
  now <- getTime
  admin <- allocateParty "admin"
  alice <- allocateParty "alice"
  bob <- allocateParty "bob"
  provider1 <- allocateParty "provider1"
  provider2 <- allocateParty "provider2"
  let settlement = V1.SettlementInfo with
        executor = provider1
        settlementRef = V1.Reference with
          id = "settlement1"
          cid = None
        meta = Metadata with
          values = TextMap.fromList
            [ (TSU.extraExecutorsMetaField, partyToText provider2)
            ]
        requestedAt = now
        allocateBefore = now `addRelTime` days 1
        settleBefore = now `addRelTime` days 2
  let allocationViewV1 = V1.AllocationView with
        holdingCids = []
        meta = emptyMetadata
        allocation = V1.AllocationSpecification with
          settlement
          transferLegId = "leg1"
          transferLeg = V1.TransferLeg with
            sender = alice
            receiver = bob
            amount = 10.0
            instrumentId = V1.InstrumentId with
              admin
              id = "X"
            meta = emptyMetadata
  let expectedActions = Map.fromList
        -- TODO(#4517): also test available actions with sender accounts
        [ (V2.AA_Settle, [[provider1, provider2, admin]])
        , (V2.AA_Cancel, [[provider1, provider2]])
        , (V2.AA_Withdraw, [[alice]])
        ]

  checkEq "allocationV1_availableActionsDefault" expectedActions $
    TSU.allocationV1_availableActionsDefault allocationViewV1

  pure ()



checkEq : (Eq a, Show a) => Text -> a -> a -> Script ()
checkEq prefix expected actual =
  unless (actual == expected) $
    fail $ T.unlines
      [ prefix <> ": actual values do not match expected values"
      , "  actual: " <> show actual
      , "  expected: " <> show expected
      ]
