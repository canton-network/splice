-- | Tests for `ensureReceiptAllocation` .
module Splice.Tests.TestAllocationRequestDefaults where

import DA.Time

import Daml.Script

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.AllocationRequestV1 qualified as V1
import Splice.Api.Token.AllocationRequestV2 qualified as V2
import Splice.Api.Token.HoldingV2 qualified as V2

import Splice.TokenStandard.Utils qualified as TSU

import Splice.Testing.Utils
import Splice.Testing.Apps.TradingAppV2 qualified as TradingAppV2


data TestEnv = TestEnv with
  provider : Party
  accountProvider : Party
  alice : Party
  bob : Party
  admin : Party
  reqCidV1 : ContractId V1.AllocationRequest
  reqCidV2 : ContractId V2.AllocationRequest


test_allocationRequestV1_Reject : Script ()
test_allocationRequestV1_Reject = runTest $ \TestEnv{..} -> do
  submitMustFail''
    ( expectMessageContains "'actor' is not a member of 'allowed actors'" <>
      expectMessageContains ("allowed actors: " <> show [alice, accountProvider])
    )
    (actAs provider) $ exerciseCmd reqCidV1 V1.AllocationRequest_Reject with
    actor = provider
    extraArgs = emptyExtraArgs
  submit alice $ exerciseCmd reqCidV1 V1.AllocationRequest_Reject with
    actor = alice
    extraArgs = emptyExtraArgs

test_allocationRequestV1_Withdraw : Script ()
test_allocationRequestV1_Withdraw = runTest $ \TestEnv{..} -> do
  result <- trySubmit
    (actAs alice) $ exerciseCmd reqCidV1 V1.AllocationRequest_Withdraw with
      extraArgs = emptyExtraArgs
  case result of
    Left (AuthorizationError _) -> pure ()
    err -> fail $ "Expected AuthorizationError, got: " <> show err

  submit provider $ exerciseCmd reqCidV1 V1.AllocationRequest_Withdraw with
    extraArgs = emptyExtraArgs

test_allocationRequestV2_Accept_owner : Script ()
test_allocationRequestV2_Accept_owner = runTest $ \TestEnv{..} -> do
  submitMustFail''
    ( expectMessageContains "'actors' does not have the same elements as one of 'allowed actors'" <>
      expectMessageContains ("allowed actors: " <> show [[alice], [accountProvider]])
    )
    (actAs provider) $ exerciseCmd reqCidV2 V2.AllocationRequest_Accept with
    actors = [provider]
    extraArgs = emptyExtraArgs
  submit alice $ exerciseCmd reqCidV2 V2.AllocationRequest_Accept with
    actors = [alice]
    extraArgs = emptyExtraArgs

-- the account provider can accept as well in the default implementation chosen in the TradingAppV2
test_allocationRequestV2_Accept_accountProvider : Script ()
test_allocationRequestV2_Accept_accountProvider = runTest $ \TestEnv{..} -> do
  submit accountProvider $ exerciseCmd reqCidV2 V2.AllocationRequest_Accept with
    actors = [accountProvider]
    extraArgs = emptyExtraArgs

test_allocationRequestV2_Reject_owner : Script ()
test_allocationRequestV2_Reject_owner = runTest $ \TestEnv{..} -> do
  submitMustFail''
    ( expectMessageContains "'actors' does not have the same elements as one of 'allowed actors'" <>
      expectMessageContains ("allowed actors: " <> show [[alice], [accountProvider]])
    )
    (actAs provider) $ exerciseCmd reqCidV2 V2.AllocationRequest_Reject with
    actors = [provider]
    extraArgs = emptyExtraArgs

  submit alice $ exerciseCmd reqCidV2 V2.AllocationRequest_Reject with
    actors = [alice]
    extraArgs = emptyExtraArgs

-- the account provider can reject as well in the default implementation chosen in the TradingAppV2
test_allocationRequestV2_Reject_accountProvider : Script ()
test_allocationRequestV2_Reject_accountProvider = runTest $ \TestEnv{..} -> do
  submit accountProvider $ exerciseCmd reqCidV2 V2.AllocationRequest_Reject with
    actors = [accountProvider]
    extraArgs = emptyExtraArgs


test_allocationRequestV2_Withdraw : Script ()
test_allocationRequestV2_Withdraw = runTest $ \TestEnv{..} -> do
  submitMustFail''
    ( expectMessageContains "'actors' does not have the same elements as one of 'allowed actors'" <>
      expectMessageContains ("allowed actors: " <> show [[provider]])
    )
    (actAs alice) $ exerciseCmd reqCidV2 V2.AllocationRequest_Withdraw with
    actors = [alice]
    extraArgs = emptyExtraArgs
  submit provider $ exerciseCmd reqCidV2 V2.AllocationRequest_Withdraw with
    actors = [provider]
    extraArgs = emptyExtraArgs


-- Shared test infrastructure
-----------------------------

runTest : (TestEnv -> Script a) -> Script ()
runTest mkTest = do
  provider <- allocateParty "provider"
  accountProvider <- allocateParty "accountProvider"
  alice <- allocateParty "alice"
  bob <- allocateParty "bob"
  admin <- allocateParty "admin"
  let instrId = V2.InstrumentId with
        id = "X"
        admin

  let aliceAccount = V2.Account with
        owner = Some alice
        id = "alice-account"
        provider = Some accountProvider
  let bobAccount = TSU.basicAccount bob

  now <- getTime
  tradeCid <- submit provider $ createCmd TradingAppV2.OTCTrade with
    venue = provider
    tradeLegs =
      [ TradingAppV2.TradeLeg with
          admin = instrId.admin
          leg = V2.TransferLeg with
            transferLegId = "leg1"
            sender = aliceAccount
            receiver = bobAccount
            amount = 10.0
            instrumentId = instrId.id
            meta = emptyMetadata
      ]
    createdAt = now
    settleAt = now `addRelTime` days 10
    settlementDeadline = None

  submit provider $ exerciseCmd tradeCid TradingAppV2.OTCTrade_RequestAllocations

  [(aliceReqCid, _)] <- queryInterface @V2.AllocationRequest alice

  mkTest $ TestEnv with
    reqCidV1 = coerceContractId aliceReqCid
    reqCidV2 = aliceReqCid
    ..

  -- the request is gone
  [] <- queryInterface @V2.AllocationRequest alice

  pure ()
