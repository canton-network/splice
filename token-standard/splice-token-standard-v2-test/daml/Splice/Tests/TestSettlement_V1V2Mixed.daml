-- | Daml script tests showing how to batch settle allocations created using
-- both the V1 and V2 allocation factories in a single settlement using the V2
-- settlement factory.
--
-- Uses Amulet as the test token, but can be extened to use multiple tokens from
-- different registries as well.
module Splice.Tests.TestSettlement_V1V2Mixed where

import Daml.Script

import DA.Action
import DA.Foldable (forA_)
import DA.Map qualified as Map
import DA.List (dedupSort)
import DA.Optional
import DA.Set qualified as Set
import DA.Text qualified as T
import DA.TextMap qualified as TextMap
import DA.Time

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.AllocationV1 qualified as V1
import Splice.Api.Token.AllocationRequestV1 qualified as V1
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.AllocationRequestV2 qualified as V2

import Splice.TokenStandard.Utils

import Splice.Amulet (LockedAmulet, LockedAmulet_OwnerExpireLockV2(..))

import Splice.Testing.Apps.TradingAppV2 qualified as TradingAppV2
import Splice.Testing.Apps.TradingAppV2_Backend qualified as TradingAppV2

import Splice.Testing.Utils
import Splice.Testing.Registries.AmuletRegistryV2 qualified as AmuletRegistryV2
import Splice.Testing.Registries.TestTokenV1_RegistryV1 qualified as TestTokenV1_RegistryV1
import Splice.Testing.Registries.TestTokenV2_RegistryV2 qualified as TestTokenV2_RegistryV2
import Splice.Testing.TokenStandard.WalletClientV2 qualified as WalletClientV2

import Splice.Testing.Registries.AmuletRegistry qualified as AmuletRegistryV1
import Splice.Testing.TokenStandard.MultiRegistry qualified as MultiRegistry


-- Tests definitions
--------------------

data TestEnvironment = TestEnvironment
  with
    venue : Party
    venueAccount : V2.Account
    venueSpecialAccount : V2.Account
    alice : Party
    aliceAccount : V2.Account
    bob : Party
    bobAccount : V2.Account
    charlie : Party
    dora : Party
    allParties : [Party]
    registryV2 : AmuletRegistryV2.AmuletRegistry
    registryV1 : AmuletRegistryV1.AmuletRegistry
    tty1Registry : TestTokenV1_RegistryV1.TestTokenV1Registry
    tty2Registry : TestTokenV2_RegistryV2.TestTokenV2Registry
    registries : MultiRegistry.MultiRegistry
    amuletId : V2.InstrumentId

data TestInstrumentId
  = AM  -- amulet
  | X1 | Y1 | Z1  -- V1 assets with different instrument-ids
  | X2 | Y2 | Z2  -- V2 assets with different instrument-ids
  deriving (Eq, Show)

data TestHolding = TestHolding with
    owner : Party
    amount : Decimal
    locked : Bool
    instrumentId : TestInstrumentId
  deriving (Eq, Show)

mkH : TestInstrumentId -> Party -> Decimal -> TestHolding
mkH instrumentId owner amount = TestHolding owner amount False instrumentId

mkLH : TestInstrumentId -> Party -> Decimal -> TestHolding
mkLH instrumentId owner amount = TestHolding owner amount True instrumentId

data TestLeg = TestLeg with
    sender : V2.Account
    receiver : V2.Account
    amount : Decimal
    instrumentId : TestInstrumentId
  deriving (Eq, Show)

data TestWorkflow
  = SettleTrade
  | WithdrawAndCancel with
      withdrawers : [Party]
      locksToExpireBeforeWithdrawal : [TestHolding]
  deriving (Eq, Show)

data TestTrade = TestTrade with
    partiesWithV1Wallet : [Party]
    partiesWithSettlementAgreements : [Party]
    initialHoldings : [TestHolding]
    transferLegs : [TestLeg]
    expectedNumRequests : Int
    expectedNumAllocationsV1 : Int
      -- ^ note: V1 allocation means *V1-only* allocations
    expectedNumAllocationsV2 : Int
    expectedHoldingsAfterAllocation : [TestHolding]
    testWorkflow : TestWorkflow
    expectedFinalHoldings : [TestHolding]
  deriving (Eq, Show)


-- Test suite: single transfers
-------------------------------

singleTransferTest : TestEnvironment -> TestTrade
singleTransferTest TestEnvironment{..} =
  TestTrade with
    partiesWithV1Wallet = []
    partiesWithSettlementAgreements = []
    initialHoldings = [mkH AM alice 100.0]
    transferLegs = [aliceToBob]
    expectedNumRequests = 2
    expectedNumAllocationsV1 = 0
    expectedNumAllocationsV2 = 2
    expectedHoldingsAfterAllocation = [mkLH AM alice 1.0, mkH AM alice 99.0]
    testWorkflow = SettleTrade
    expectedFinalHoldings = [mkH AM bob 1.0, mkH AM alice 99.0]
  where
    aliceToBob = TestLeg with
        sender = aliceAccount
        receiver = bobAccount
        amount = 1.0
        instrumentId = AM

singleTransferTest_allV2 = runTest $ \env ->
  singleTransferTest env

singleTransferTest_senderV1 = runTest $ \env@TestEnvironment{..} ->
  (singleTransferTest env) with
    partiesWithV1Wallet = [alice]
    expectedNumAllocationsV1 = 0
    expectedNumAllocationsV2 = 2
    partiesWithSettlementAgreements = [alice, bob]

singleTransferTest_receiverV1 = runTest $ \env@TestEnvironment{..} ->
  (singleTransferTest env) with
    partiesWithV1Wallet = [bob]
    expectedNumAllocationsV1 = 0
    expectedNumAllocationsV2 = 1
    partiesWithSettlementAgreements = [bob]

singleTransferTest_allV1 = runTest $ \env@TestEnvironment{..} ->
  (singleTransferTest env) with
    partiesWithV1Wallet = [alice, bob]
    expectedNumAllocationsV1 = 0
    expectedNumAllocationsV2 = 1
    partiesWithSettlementAgreements = [bob]

singleTransferTest_allV2_cancel = runTest $ \env@TestEnvironment{..} ->
  (singleTransferTest env) with
    testWorkflow = WithdrawAndCancel with
      withdrawers = [alice]
      locksToExpireBeforeWithdrawal = []
    expectedFinalHoldings = [mkH AM alice 99.0, mkH AM alice 1.0]


-- Test suite: bilateral DvPs with fees
---------------------------------------

bilateralDvPWithFeeTest : TestEnvironment -> TestTrade
bilateralDvPWithFeeTest TestEnvironment{..} =
  TestTrade with
    partiesWithV1Wallet = []
    partiesWithSettlementAgreements = []
    initialHoldings =
      [ mkH AM alice 100.0
      , mkH AM bob 100.0
      , mkH X2 bob 50.0
      ]
    transferLegs =
      [ aliceToBob, bobToVenueAM
      , bobToAliceX2
      , bobToVenueX2
      ]
    expectedNumRequests = 3
    expectedNumAllocationsV1 = 0
    expectedNumAllocationsV2 = 4 -- alice, bob for both admins, venue does not allocate
    expectedHoldingsAfterAllocation =
      [ mkLH AM alice 20.0, mkH AM alice 80.0
      , mkH AM bob 100.0
      , mkH X2 bob 8.0, mkLH X2 bob 42.0
      ]
    testWorkflow = SettleTrade
    expectedFinalHoldings =
      [ mkH AM alice 80.0
      , mkH X2 alice 40.0
      , mkH AM bob 100.0, mkH AM bob 19.0, mkH X2 bob 8.0
      , mkH AM venue 1.0, mkH X2 venue 2.0
      ]
  where
    aliceToBob = TestLeg with
        sender = aliceAccount
        receiver = bobAccount
        amount = 20.0
        instrumentId = AM
    bobToAliceX2 = TestLeg with
        sender = bobAccount
        receiver = aliceAccount
        amount = 40.0
        instrumentId = X2
    bobToVenueAM = TestLeg with
        sender = bobAccount
        receiver = basicAccount venue
        amount = 1.0
        instrumentId = AM
    bobToVenueX2 = TestLeg with
        sender = bobAccount
        receiver = venueSpecialAccount
        amount = 2.0
        instrumentId = X2

bilateralDvPWithFeeTest_onlyV2 = runTest $ \env ->
  bilateralDvPWithFeeTest env

bilateralDvPWithFeeTest_aliceV1 = runTest $ \env@TestEnvironment{..} ->
  (bilateralDvPWithFeeTest env) with
    partiesWithV1Wallet = [alice]
    partiesWithSettlementAgreements = [alice]
    expectedNumAllocationsV1 = 0
    expectedNumAllocationsV2 = 3

bilateralDvPWithFeeTest_bobV1 = runTest $ \env@TestEnvironment{..} ->
  (bilateralDvPWithFeeTest env) with
    partiesWithV1Wallet = [bob]
    expectedNumAllocationsV1 = 0
    expectedNumAllocationsV2 = 5
    partiesWithSettlementAgreements = [bob]
    expectedHoldingsAfterAllocation =
      [ mkLH AM alice 20.0, mkH AM alice 80.0
      , mkH AM bob 99.0, mkLH AM bob 1.0  -- Bob allocate Amulet, as V1 allocation flows don't do netting
      , mkH X2 bob 8.0, mkLH X2 bob 40.0, mkLH X2 bob 2.0
      ]
    expectedFinalHoldings =
      [ mkH AM alice 80.0
      , mkH X2 alice 40.0
      , mkH AM bob 99.0, mkH AM bob 20.0, mkH X2 bob 8.0
      , mkH AM venue 1.0, mkH X2 venue 2.0
      ]

bilateralDvPWithFeeTest_allV1 = runTest $ \env@TestEnvironment{..} ->
  (bilateralDvPWithFeeTest env) with
    partiesWithV1Wallet = [alice, bob]
    expectedNumAllocationsV1 = 0
    expectedNumAllocationsV2 = 4  -- one for each sender of a leg
    partiesWithSettlementAgreements = [alice, bob]
    expectedHoldingsAfterAllocation =
      [ mkLH AM alice 20.0, mkH AM alice 80.0
      , mkH AM bob 99.0, mkLH AM bob 1.0  -- Bob allocate Amulet, as V1 allocation flows don't do netting
      , mkH X2 bob 8.0, mkLH X2 bob 40.0, mkLH X2 bob 2.0
      ]
    expectedFinalHoldings =
      [ mkH AM alice 80.0
      , mkH X2 alice 40.0
      , mkH AM bob 99.0, mkH AM bob 20.0, mkH X2 bob 8.0
      , mkH AM venue 1.0, mkH X2 venue 2.0
      ]

bilateralDvPWithFeeTest_onlyV2_cancel = runTest $ \env@TestEnvironment{..} ->
  (bilateralDvPWithFeeTest env) with
    testWorkflow = WithdrawAndCancel with
      withdrawers = []
      locksToExpireBeforeWithdrawal = [mkLH AM alice 20.0]
    expectedFinalHoldings =
      [ mkH AM alice 80.0, mkH AM alice 20.0
      , mkH AM bob 100.0
      , mkH X2 bob 8.0, mkH X2 bob 42.0
      ]


-- Test suite: multilateral DvPs with fees
---------------------------------------

multiDvPWithFeeTest : TestEnvironment -> TestTrade
multiDvPWithFeeTest TestEnvironment{..} =
  TestTrade with
    partiesWithV1Wallet = []
    partiesWithSettlementAgreements =
      [alice, bob] -- We need settlement agreements due to the V1 asset transfer from bob to alice
    initialHoldings =
      [ mkH AM alice 100.0
      , mkH AM bob 100.0
      , mkH X1 bob 50.0
      , mkH X2 bob 20.0, mkH Y2 bob 3.0
      ]
    transferLegs =
      [ aliceToBob, bobToVenue, bobToAliceX2, bobToAliceY2
      , bobToAliceX1
      ]
    expectedNumRequests = 2
    expectedNumAllocationsV1 = 1
    expectedNumAllocationsV2 = 4
    expectedHoldingsAfterAllocation =
      [ mkLH AM alice 20.0, mkH AM alice 80.0
      , mkH AM bob 100.0
      , mkH X1 bob 10.0, mkLH X1 bob 40.0
      , mkH X2 bob 15.0, mkLH X2 bob 5.0, mkLH Y2 bob 0.3, mkH Y2 bob 2.7
      ]
    testWorkflow = SettleTrade
    expectedFinalHoldings =
      [ mkH AM alice 80.0
      , mkH X1 alice 40.0
      , mkH X2 alice 5.0, mkH Y2 alice 0.3
      , mkH AM bob 100.0, mkH AM bob 19.0, mkH X2 bob 15.0, mkH Y2 bob 2.7
      , mkH X1 bob 10.0
      , mkH AM venue 1.0
      ]
  where
    aliceToBob = TestLeg with
        sender = aliceAccount
        receiver = bobAccount
        amount = 20.0
        instrumentId = AM
    bobToAliceX1 = TestLeg with
        sender = bobAccount
        receiver = aliceAccount
        amount = 40.0
        instrumentId = X1
    bobToAliceX2 = TestLeg with
        sender = bobAccount
        receiver = aliceAccount
        amount = 5.0
        instrumentId = X2
    bobToAliceY2 = TestLeg with
        sender = bobAccount
        receiver = aliceAccount
        amount = 0.3
        instrumentId = Y2
    bobToVenue = TestLeg with
        sender = bobAccount
        receiver = venueAccount
        amount = 1.0
        instrumentId = AM

multiDvPWithFeeTest_onlyV2 = runTest $ \env ->
  multiDvPWithFeeTest env

multiDvPWithFeeTest_alice_v1 = runTest $ \env@TestEnvironment{..} ->
  (multiDvPWithFeeTest env) with
    partiesWithV1Wallet = [alice]
    expectedNumAllocationsV1 = 1  -- allocation for bobToAliceX1
    expectedNumAllocationsV2 = 3  -- alice's V1 wallet does not create a receipt allocation

multiDvPWithFeeTest_bob_v1 = runTest $ \env@TestEnvironment{..} ->
  (multiDvPWithFeeTest env) with
    partiesWithV1Wallet = [bob]
    expectedHoldingsAfterAllocation =
      [ mkLH AM alice 20.0, mkH AM alice 80.0
      , mkH AM bob 99.0, mkLH AM bob 1.0
      , mkH X1 bob 10.0, mkLH X1 bob 40.0
      , mkH X2 bob 15.0, mkLH X2 bob 5.0, mkLH Y2 bob 0.3, mkH Y2 bob 2.7
      ]
    expectedNumAllocationsV1 = 1  -- allocation of bob for bobToAliceX1
    expectedNumAllocationsV2 = 5  -- bob (to venue AM, alice X2, alice Y2), alice (AM send, X2 receipt)
    expectedFinalHoldings =
      [ mkH AM alice 80.0
      , mkH X1 alice 40.0
      , mkH X2 alice 5.0, mkH Y2 alice 0.3
      , mkH AM bob 99.0, mkH AM bob 20.0, mkH X2 bob 15.0, mkH Y2 bob 2.7
      , mkH X1 bob 10.0
      , mkH AM venue 1.0
      ]

multiDvPWithFeeTest_all_v1 = runTest $ \env@TestEnvironment{..} ->
  (multiDvPWithFeeTest env) with
    partiesWithV1Wallet = [alice, bob]
    expectedHoldingsAfterAllocation =
      [ mkLH AM alice 20.0, mkH AM alice 80.0
      , mkH AM bob 99.0, mkLH AM bob 1.0
      , mkH X1 bob 10.0, mkLH X1 bob 40.0
      , mkH X2 bob 15.0, mkLH X2 bob 5.0, mkLH Y2 bob 0.3, mkH Y2 bob 2.7
      ]
    expectedNumAllocationsV1 = 1  -- allocation of bob for bobToAliceX1
    expectedNumAllocationsV2 = 4  -- bob (to venue AM, alice X2, alice Y2), alice (AM send)
    expectedFinalHoldings =
      [ mkH AM alice 80.0
      , mkH X1 alice 40.0
      , mkH X2 alice 5.0, mkH Y2 alice 0.3
      , mkH AM bob 99.0, mkH AM bob 20.0, mkH X2 bob 15.0, mkH Y2 bob 2.7
      , mkH X1 bob 10.0
      , mkH AM venue 1.0
      ]

multiDvPWithFeeTest_onlyV2_cancel : Script ()
multiDvPWithFeeTest_onlyV2_cancel = runTest $ \env@TestEnvironment{..} ->
  (multiDvPWithFeeTest env) with
    testWorkflow = WithdrawAndCancel with
      withdrawers = []
      locksToExpireBeforeWithdrawal = [mkLH AM alice 20.0]
    expectedFinalHoldings =
      [ mkH AM alice 80.0, mkH AM alice 20.0
      , mkH AM bob 100.0
      , mkH X1 bob 10.0, mkH X1 bob 40.0
      , mkH X2 bob 15.0, mkH X2 bob 5.0, mkH Y2 bob 0.3, mkH Y2 bob 2.7
      ]

multiDvPWithFeeTest_allV1_cancel = runTest $ \env@TestEnvironment{..} ->
