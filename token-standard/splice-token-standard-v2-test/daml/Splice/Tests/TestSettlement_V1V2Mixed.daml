      withdrawers = []
      locksToExpireBeforeWithdrawal = [mkLH AM alice 20.0]
    expectedHoldingsAfterAllocation =
      [ mkLH AM alice 20.0, mkH AM alice 80.0
      , mkH AM bob 99.0, mkLH AM bob 1.0
      , mkH X1 bob 10.0, mkLH X1 bob 40.0
      , mkH X2 bob 15.0, mkLH X2 bob 5.0, mkLH Y2 bob 0.3, mkH Y2 bob 2.7
      ]
    expectedNumAllocationsV1 = 1  -- allocation of bob for bobToAliceX1
    expectedNumAllocationsV2 = 4  -- bob (to venue AM, alice X2, alice Y2), alice (AM send)
    expectedFinalHoldings =
      [ mkH AM alice 20.0, mkH AM alice 80.0
      , mkH AM bob 99.0, mkH AM bob 1.0
      , mkH X1 bob 10.0, mkH X1 bob 40.0
      , mkH X2 bob 15.0, mkH X2 bob 5.0, mkH Y2 bob 0.3, mkH Y2 bob 2.7
      ]

multiDvPWithFeeTest_allV1_withdraw_then_cancel = runTest $ \env@TestEnvironment{..} ->
  (multiDvPWithFeeTest env) with
    partiesWithV1Wallet = [alice, bob]
    testWorkflow = WithdrawAndCancel with
      withdrawers = [alice, bob]
      locksToExpireBeforeWithdrawal = [mkLH AM alice 20.0]
    expectedHoldingsAfterAllocation =
      [ mkLH AM alice 20.0, mkH AM alice 80.0
      , mkH AM bob 99.0, mkLH AM bob 1.0
      , mkH X1 bob 10.0, mkLH X1 bob 40.0
      , mkH X2 bob 15.0, mkLH X2 bob 5.0, mkLH Y2 bob 0.3, mkH Y2 bob 2.7
      ]
    expectedNumAllocationsV1 = 1  -- allocation of bob for bobToAliceX1
    expectedNumAllocationsV2 = 4  -- bob (to venue AM, alice X2, alice Y2), alice (AM send)
    expectedFinalHoldings =
      [ mkH AM alice 20.0, mkH AM alice 80.0
      , mkH AM bob 99.0, mkH AM bob 1.0
      , mkH X1 bob 10.0, mkH X1 bob 40.0
      , mkH X2 bob 15.0, mkH X2 bob 5.0, mkH Y2 bob 0.3, mkH Y2 bob 2.7
      ]

-- | The example from CIP-112 (https://github.com/canton-foundation/cips/blob/main/cip-0112/cip-0112.md#42-uxflow-example-in-detail)
-- with Amulet and X2 taking the place of USD and X.
cipExampleTest : TestEnvironment -> TestTrade
cipExampleTest TestEnvironment{..} =
  TestTrade with
    partiesWithV1Wallet = []
    partiesWithSettlementAgreements = []
    initialHoldings =
      [ mkH AM alice 100.0
      ]
    transferLegs =
      [ -- TransferLeg with sender=alice; receiver=bob; amount=1.0; instrumentId=x,
        TestLeg with
          sender = aliceAccount
          receiver = bobAccount
          amount = 1.0
          instrumentId = X2
        -- TransferLeg with sender=bob; receiver=alice; amount=10.0; instrumentId=usd,
      , TestLeg with
          sender = bobAccount
          receiver = aliceAccount
          amount = 10.0
          instrumentId = AM
        -- TransferLeg with sender=alice; receiver=app; amount=0.1; instrumentId=usd,
      , TestLeg with
          sender = aliceAccount
          receiver = venueAccount
          amount = 0.1
          instrumentId = AM

        -- TransferLeg with sender=bob; receiver=carol; amount=1.0; instrumentId=x,
      , TestLeg with
          sender = bobAccount
          receiver = basicAccount charlie
          amount = 1.0
          instrumentId = X2
        -- TransferLeg with sender=carol; receiver=bob; amount=11.0; instrumentId=usd,
      , TestLeg with
          sender = basicAccount charlie
          receiver = bobAccount
          amount = 11.0
          instrumentId = AM
        -- TransferLeg with sender=bob; receiver=app; amount=0.11; instrumentId=usd,
      , TestLeg with
          sender = bobAccount
          receiver = venueAccount
          amount = 0.11
          instrumentId = AM

        -- TransferLeg with sender=carol; receiver=alice; amount=1.0; instrumentId=x,
      , TestLeg with
          sender = basicAccount charlie
          receiver = aliceAccount
          amount = 1.0
          instrumentId = X2
        -- TransferLeg with sender=alice; receiver=carol; amount=12.0; instrumentId=usd,
      , TestLeg with
          sender = aliceAccount
          receiver = basicAccount charlie
          amount = 12.0
          instrumentId = AM
        -- TransferLeg with sender=carol; receiver=app; amount=0.12; instrumentId=usd,
      , TestLeg with
          sender = basicAccount charlie
          receiver = venueAccount
          amount = 0.12
          instrumentId = AM
      ]
    expectedNumRequests = 3
    expectedNumAllocationsV1 = 0
    expectedNumAllocationsV2 = 6
    expectedHoldingsAfterAllocation =
      [ mkLH AM alice 2.1, mkH AM alice 97.9
      ]
    testWorkflow = SettleTrade
    expectedFinalHoldings =
      [ mkH AM alice 97.9
      , mkH AM bob 0.89
      , mkH AM charlie 0.88
      , mkH AM venue 0.33
      ]

cipExampleTest_onlyV2 = runTest $ \env ->
  cipExampleTest env


-- Test exececution infrastructure
-----------------------------------

runTest : (TestEnvironment -> TestTrade) -> Script ()
runTest mkTest = do
  env <- setupTestEnvironment
  let test = mkTest env

  -- setup initial funds
  forA_ test.initialHoldings $ \TestHolding{..} -> do
    case instrumentId of
      AM -> void $ AmuletRegistryV2.tapFaucet env.registryV2 owner amount
      tt
        | "1" `T.isSuffixOf` show tt ->
            void $ TestTokenV1_RegistryV1.mint env.tty1Registry owner (show tt) amount
        | otherwise -> do
            let instrumentName = show tt
            TestTokenV2_RegistryV2.mint env.tty2Registry (basicAccount owner) instrumentName amount

  checkHoldings env "initial holdings" test.initialHoldings

  -- setup settlement agreements
  forA_ test.partiesWithSettlementAgreements $ \trader -> do
    submit (actAs env.venue <> actAs trader) $ createCmd TradingAppV2.TradeSettlementAgreement with
      venue = env.venue
      trader

  -- register OTC trade
  let tradeLegs = do
        (i, TestLeg{..}) <- zip [1..length test.transferLegs] test.transferLegs
        let iid = mkInstrumentId env instrumentId
        let reason = T.intercalate "-" ["trade-leg", show i, partyToText (regularAccountOwner sender), partyToText (regularAccountOwner receiver)]
        let leg = V2.TransferLeg with
              transferLegId = "leg" <> show i
              sender
              receiver
              amount
              instrumentId = iid.id
              meta = reasonToMeta reason emptyMetadata
        pure TradingAppV2.TradeLeg with
          leg
          admin = iid.admin

  now <- getTime
  let settlementDeadline = now `addRelTime` hours 2
  let otcTrade = TradingAppV2.OTCTrade with
        venue = env.venue
        tradeLegs
        settleAt = now `addRelTime` hours 1
        createdAt = now
        settlementDeadline = Some settlementDeadline
  otcTradeCid <- submit env.venue $ createCmd otcTrade

  -- create allocation requests
  submit env.venue $ exerciseCmd otcTradeCid TradingAppV2.OTCTrade_RequestAllocations

  reqs <- query @TradingAppV2.OTCTradeAllocationRequest env.venue
  checkEqual "number of allocation requests" test.expectedNumRequests (length reqs)

  -- have all parties except the venue accept the allocation requests
  forA_ (filter (/= env.venue) env.allParties) $ \trader -> do
    if trader `elem` test.partiesWithV1Wallet
      then do
        reqs <- WalletClientV2.listAllocationRequestsV1 trader
        forA_ reqs $ \(_, req) -> do
          debug req
          WalletClientV2.acceptAndCreateRequestedAllocationsV1 env.registries trader req
      else do
        reqs <- WalletClientV2.listAllocationRequestsV2 (basicAccount trader) trader
        -- Batch all request acceptances together in a single transaction
        -- Note: whether to do this or not is a wallet UX concern.
        batches <- forA reqs $ \req -> do
          WalletClientV2.mkAcceptAndCreateRequestedAllocationsV2 env.registries trader req
        void $ WalletClientV2.executeTSABatch env.registries trader (mconcat batches)

  -- check locked holdings
  checkHoldings env "holdings after allocation" test.expectedHoldingsAfterAllocation

  -- check that a settleable trade exists
  trades <- TradingAppV2.querySettleableTrades env.registries env.venue
  trade <- expectOneElement "settleable trade" (show . (.batchesByAdmin)) trades

  allocationsV1 <- queryInterface @V1.Allocation env.venue
  allocationsV2 <- queryInterface @V2.Allocation env.venue
  let v2Cids = Set.fromList $ map fst allocationsV2
  let v1OnlyAllocations = filter (\(cid, _) -> not (Set.member (upcast cid) v2Cids)) allocationsV1
  checkEqual "number of allocations v1" test.expectedNumAllocationsV1 (length v1OnlyAllocations)
  checkEqual "number of allocations v2" test.expectedNumAllocationsV2 (length allocationsV2)

  case test.testWorkflow of
    SettleTrade -> do
      (result, _changes) <- TradingAppV2.settleWithTradeAgreements trade
      -- Basic checks on V1 tx history being present on the Allocation_Settle choice results
      forA_ (Map.toList result.resultsByAdminV2) $ \(admin, settleBatchResult) -> do
        forA_ settleBatchResult.allocationSettleResults $ \settleResult -> do
          let hasReason = reasonMetaKey `TextMap.member` settleResult.meta.values
          let hasExpectedTxKind = case TextMap.lookup txKindMetaKey settleResult.meta.values of
                None -> False
                Some txKind -> txKind `elem` ["mint", "burn", "transfer", "settle-V2-allocation"]
          unless (hasReason && hasExpectedTxKind) $ fail $ T.unlines $
            [ "Missing expected metadata keys in settle result for admin " <> show admin
            , "Settle result metadata: " <> show settleResult.meta
            ]

    WithdrawAndCancel {..} -> do
      -- expire locks on holdings specified holdings
      forA_ locksToExpireBeforeWithdrawal $ \TestHolding{..} -> do
        candidates <- WalletClientV2.listHoldings owner env.amuletId
        case find (\(_, h) -> h.amount == amount && isSome h.lock) candidates of
          None -> fail $ T.unlines
            [ "No matching locked holding found for " <> show owner <> " with amount " <> show amount
            , "Candidates:" <> show candidates
            ]
          Some (holdingCid, holding) -> do
            setTime settlementDeadline
            let cid = fromInterfaceContractId @LockedAmulet holdingCid
            let owner = regularAccountOwner holding.account
            submit owner $ exerciseCmd cid LockedAmulet_OwnerExpireLockV2

      -- withdraw allocations for the specified withdrawers
      forA_ withdrawers $ \withdrawer -> do
        -- withdraw V2 allocations first
        allocs <- queryInterface @V2.Allocation withdrawer
        forA_ allocs $ \(allocCid, optAllocView) -> do
          let Some allocView = optAllocView
          WalletClientV2.withdrawAllocationV2 env.registries withdrawer (allocCid, allocView)
        allocsAfterV2 <- queryInterface @V2.Allocation withdrawer
        unless (null allocsAfterV2) $ fail $ T.unlines
          [ "Expected all V2 allocations for withdrawer " <> show withdrawer <> " to be withdrawn, but some remain: " <> show allocsAfterV2
          ]
        -- withdraw remaining V1-only allocations
        allocs <- queryInterface @V1.Allocation withdrawer
        forA_ allocs $ \(allocCid, optAllocView) -> do
          let Some allocView = optAllocView
          WalletClientV2.withdrawAllocationV1 env.registries withdrawer (allocCid, allocView)
        allocsAfterV1 <- queryInterface @V1.Allocation withdrawer
        unless (null allocsAfterV1) $ fail $ T.unlines
          [ "Expected all V1 allocations for withdrawer " <> show withdrawer <> " to be withdrawn, but some remain: " <> show allocsAfterV1
          ]

      -- cancel trade
      trades <- TradingAppV2.queryTradesWithAllocations env.venue
      trade <- expectOneElement "trade to cancel" show trades
      TradingAppV2.cancelWithTradeAgreements env.registries trade

      pure ()

  -- check final holdings
  checkHoldings env ("holdings after " <> show test.testWorkflow) test.expectedFinalHoldings

  -- check that no allocations or allocation requests are left over
  [] <- queryInterface @V1.Allocation env.venue
  [] <- queryInterface @V1.AllocationRequest env.venue
  [] <- queryInterface @V2.AllocationRequest env.venue
  [] <- queryInterface @V2.AllocationRequest env.venue

  pure ()

setupTestEnvironment : Script TestEnvironment
setupTestEnvironment = do
  allParties <- forA ["venue","alice", "bob", "charlie", "dora"] \n -> do
    p <- allocatePartyExact n
    WalletClientV2.createBatchingUtility p
    pure p
  let [venue, alice, bob, charlie, dora] = allParties
  let venueAccount = basicAccount venue
  let venueSpecialAccount = V2.Account with
        owner = Some venue
        provider = None
        id = "special-account"
  let aliceAccount = basicAccount alice
  let bobAccount = basicAccount bob

  -- amulet registry setup
  registryV2 <- AmuletRegistryV2.initialize AmuletRegistryV2.defaultAmuletRegistryConfig
  let amuletId = registryV2.instrumentId
  let registryV1 = AmuletRegistryV1.AmuletRegistry with
        dso = registryV2.dso
        instrumentId = downcast amuletId

  -- test token v1 registry setup
  tty1Registry <- TestTokenV1_RegistryV1.initialize TestTokenV1_RegistryV1.defaultTestTokenV1RegistryConfig

  -- test token v2 registry setup
  tty2Registry <- TestTokenV2_RegistryV2.initialize TestTokenV2_RegistryV2.defaultTestTokenV2RegistryConfig

  let registries = Map.fromList
        [ (registryV2.dso, MultiRegistry.mkRegistryApisV1V2 registryV1 registryV2)
        , (tty1Registry.admin, MultiRegistry.mkRegistryApisV1 tty1Registry)
        , (tty2Registry.admin, MultiRegistry.mkRegistryApisV1V2 tty2Registry tty2Registry )
        ]
  pure TestEnvironment with ..

mkInstrumentId : TestEnvironment -> TestInstrumentId -> V2.InstrumentId
mkInstrumentId env = \case
  AM -> env.amuletId
  symbol
    | "1" `T.isSuffixOf` show symbol -> V2.InstrumentId with
        id = show symbol
        admin = env.tty1Registry.admin
    | otherwise -> V2.InstrumentId with
        id = show symbol
        admin = env.tty2Registry.admin

checkHoldings : TestEnvironment -> Text -> [TestHolding] -> Script ()
checkHoldings env description expectedHoldings = do
  let holdingsByOwner = Map.fromListWithR (++) $ do
        TestHolding{..} <- expectedHoldings
        pure (owner, [(amount, locked, mkInstrumentId env instrumentId)])
  forA_ env.allParties $ \owner -> do
    visibleHoldings <- WalletClientV2.listVisibleHoldings owner
    let actualHoldings = filter (\(_, h) -> h.account.owner == Some owner) visibleHoldings
    case Map.lookup owner holdingsByOwner of
      None -> unless (Prelude.null actualHoldings) $
        fail $ T.unlines $
          description <> ": expected no holdings for " <> show owner <> ", but got: " :: map (show . snd) actualHoldings
      Some expectedAmountAndLocks -> do
        let actualAmounts = dedupSort [ (h.amount, isSome h.lock, h.instrumentId) | (_, h) <- actualHoldings ]
        let expectedAmounts = dedupSort expectedAmountAndLocks
        unless (actualAmounts == expectedAmounts) $
          fail $ T.unlines $
            [ description <> ": holdings do not match up for " <> show owner
            , "expected: " <> show expectedAmounts
            , "actual: " <> show actualAmounts
            ]

checkEqual : (Show a, Eq a) => Text -> a -> a -> Script ()
checkEqual description expected actual =
  unless (expected == actual) $
    fail $ T.unlines $
      [ description <> ": values do not match"
      , "expected: " <> show expected
      , "actual: " <> show actual
      ]
