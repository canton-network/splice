{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "required": [
    "networkName"
  ],
  "properties": {
    "securityContexts": {
      "type": "object",
      "properties": {
        "pod": {
          "type": "object"
        },
        "docs": {
          "type": "object"
        },
        "gcsProxy": {
          "type": "object"
        }
      },
      "required": ["pod", "docs", "gcsProxy"]
    },
    "serviceAccountName": {
      "type": "string"
    },
    "networkName": {
      "type": "string"
    },
    "docs": {
      "type": "object",
      "required": [
        "imageName"
      ],
      "properties": {
        "imageName": {
          "type": "string"
        }
      }
    },
    "gcsProxy": {
      "type": "object",
      "required": [
        "imageName"
      ],
      "properties": {
        "imageName": {
          "type": "string"
        }
      }
    }
  }
}
